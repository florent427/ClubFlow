# Postgres (docker-compose : service db)
# PowerShell : $env:DATABASE_URL="postgresql://clubflow:clubflow@localhost:5432/clubflow"
# cmd.exe : set DATABASE_URL=postgresql://clubflow:clubflow@localhost:5432/clubflow
DATABASE_URL="postgresql://clubflow:clubflow@localhost:5432/clubflow"
JWT_SECRET=change-me-in-production
PORT=3000

# Origine(s) du front admin, séparées par des virgules si besoin (CORS).
# En NODE_ENV≠production, localhost et 127.0.0.1 avec n’importe quel port sont aussi autorisés.
# ADMIN_WEB_ORIGIN=http://localhost:5173

# Mot de passe du compte démo seed (admin@clubflow.local), défaut : ChangeMe!
# SEED_ADMIN_PASSWORD=ChangeMe!

# Telegram (Bot API) : le token se configure dans apps/api/.env — voir apps/api/.env.example (TELEGRAM_BOT_TOKEN).
