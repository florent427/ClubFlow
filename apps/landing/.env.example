# Landing marketing — apps/landing/
# En dev local : copier vers .env.local

# URL publique de l'API ClubFlow (utilisée pour le signup, vérification slug, etc.)
LANDING_API_URL=http://localhost:3000/graphql

# URL de l'admin (où l'utilisateur est redirigé après login depuis la landing)
LANDING_ADMIN_URL=http://localhost:5173

# Base du domaine vitrine fallback (ex: <slug>.clubflow.topdigital.re)
# Affiché dans les messages "votre vitrine sera disponible sur..."
LANDING_VITRINE_BASE=localhost:5175
