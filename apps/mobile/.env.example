# URL du endpoint GraphQL (dev : API Nest sur le port 3000).
# Émulateur Android : souvent http://10.0.2.2:3000/graphql
# Simulateur iOS / web : http://localhost:3000/graphql
# Appareil physique : IP LAN de la machine, ex. http://192.168.1.10:3000/graphql
EXPO_PUBLIC_GRAPHQL_HTTP=http://localhost:3000/graphql

# Admin web (bouton « Administration » : ouverture dans le navigateur ; pas de copie JWT).
EXPO_PUBLIC_ADMIN_APP_URL=http://localhost:5173/

# Portail web (utilisé pour générer le lien d'invitation famille
# `${PORTAL_ORIGIN}/rejoindre?token=...`). Sur appareil physique, mettre
# l'IP LAN si vous voulez que les invités puissent ouvrir le lien depuis
# leur téléphone via Wi-Fi local.
EXPO_PUBLIC_PORTAL_ORIGIN=http://localhost:5173
