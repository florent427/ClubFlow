# apps/mobile/.env.staging — copié dans EAS env via eas.json profile preview
# Si tu lances `expo start` en local en mode staging :
#   cp .env.staging .env && npm run start
EXPO_ENV=staging
EXPO_PUBLIC_API_BASE=https://staging.api.clubflow.topdigital.re
EXPO_PUBLIC_GRAPHQL_HTTP=https://staging.api.clubflow.topdigital.re/graphql
EXPO_PUBLIC_ADMIN_APP_URL=https://staging.app.clubflow.topdigital.re
