# Base — copier vers .env et ajuster
DATABASE_URL="postgresql://user:pass@localhost:5432/clubflow"

# Club unique MVP (UUID). Après `npm run db:seed`, copier la valeur affichée « CLUB_ID=… ».
CLUB_ID=""

JWT_SECRET="change-me"
# Durée du JWT d’accès (portail membre, mobile, mutations auth). Ex. 15m, 7d, 365d.
# none (ou laisser vide) = pas d’expiration du jeton — pratique en dev ; à éviter en prod sans autre contrôle.
JWT_EXPIRES_IN="none"
REFRESH_SECRET="change-me-too"

# Admin (origines CORS, séparées par des virgules en prod)
# Dev local : http://localhost:5173
# Prod : https://app.clubflow.topdigital.re,https://clubflow.topdigital.re,https://portail.clubflow.topdigital.re,https://sksr.re
ADMIN_WEB_ORIGIN="http://localhost:5173"

# Origine de la landing marketing (séparée de l'admin pour CORS du formulaire signup)
# Dev local : http://localhost:5176
# Prod : https://clubflow.topdigital.re
LANDING_ORIGIN="http://localhost:5176"

# hCaptcha secret (anti-bot sur la mutation createClubAndAdmin).
# Si non défini → captcha désactivé (OK en dev). En prod, générer via
# https://dashboard.hcaptcha.com → New Site → copier le "Secret Key".
# La clé publique correspondante doit être dans landing/.env (NEXT_PUBLIC_HCAPTCHA_SITE_KEY).
# HCAPTCHA_SECRET=0xAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# CORS : clients sans en-tête Origin (Expo / React Native). En dev, autorisé par défaut.
# En production, ne pas activer sauf besoin explicite (applications natives).
# CORS_ALLOW_NO_ORIGIN=true

# Port API (même valeur en local et sur serveur si reverse-proxy)
PORT=3000

# --- E-mail : relais SMTP (Mailpit, Postfix, OVH, etc.) ---
#
# Prod (API sur hôte + Postfix profile relay) — après : docker compose --profile relay up -d db postfix
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=2525
#   SMTP_SECURE=false
# IP publique utilisée par Postfix pour sortir vers Internet (alignement SPF MVP quand SMTP_DNS_SPF_CHECK=true).
# SMTP_PUBLIC_EGRESS_IP=203.0.113.10
# true = refreshDomain exige un SPF TXT avec ip4: égal à SMTP_PUBLIC_EGRESS_IP (voir runbook + spec).
# SMTP_DNS_SPF_CHECK=false
# Adresse de collecte DMARC (RUA), optionnel — si défini, l’admin reçoit une suggestion TXT _dmarc.
# SMTP_DMARC_RUA_EMAIL=dmarc@example.com
# Bloc SPF suggéré à l’enregistrement du domaine : v=spf1 ip4:<SMTP_PUBLIC_EGRESS_IP> ~all (phase test ; passer à -all quand l’IP est stable).
#
# Test local rapide :
#   docker run -d --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit
#
# --- Brevo (test livraison réelle, ex. Gmail) ---
# Console : https://app.brevo.com → « SMTP & API » → générer / copier la **clé SMTP** (ce n’est ni le mot de passe du compte ni la clé API REST v3).
# **SMTP_USER** : l’adresse e-mail d’identification SMTP affichée par Brevo (souvent la même que ton compte).
# **Expéditeur** : le domaine ou l’adresse « From » utilisée par ClubFlow doit être **autorisée / vérifiée** dans Brevo (Senders, domaines, DKIM).
# Nodemailer : port 587 = STARTTLS → SMTP_SECURE=false (voir smtp-mail.transport.ts).
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=ton-login-smtp@example.com
# SMTP_PASS=xsmtpsib-xxxxxxxx
#
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=

# Si « false » : le bouton « Vérifier » ne passera pas le domaine en VERIFIED (mode strict, rare).
# Par défaut les domaines sont acceptés après vérif : la délivrabilité (SPF/DKIM) est à votre charge côté DNS/serveur.
SMTP_AUTO_VERIFY_DOMAIN=true

# URL publique de l’API (optionnel, pour d’autres modules)
API_PUBLIC_URL=http://localhost:3000

# Portail membre (liens e-mail de vérification, redirect OAuth)
MEMBER_PORTAL_ORIGIN=http://localhost:5174

# Jetons de vérification e-mail (HMAC) — à changer en prod
EMAIL_VERIFICATION_SECRET="change-me-email-verify"

# --- Telegram (Bot API) ---
# Créer le bot avec @BotFather (https://t.me/BotFather) → commande /newbot.
# Copier le token HTTP API ici. Ne pas commiter le .env rempli ; ne pas exposer ce secret au front (admin / Vite).
TELEGRAM_BOT_TOKEN=
# Nom d’utilisateur du bot **sans** @ (ex. MonClub_bot) — pour les liens t.me/... et /start.
TELEGRAM_BOT_USERNAME=
# Optionnel : même valeur que le « secret token » configuré chez BotFather pour le webhook
# (header X-Telegram-Bot-Api-Secret-Token sur POST /webhooks/telegram).
TELEGRAM_WEBHOOK_SECRET=

# --- Secrets chiffrés par club (AES-256-GCM) ---
# Clé maîtresse qui chiffre/déchiffre les secrets stockés par club en base
# (clé OpenRouter de l'IA, futurs secrets PSP). Sans elle, ces secrets sont
# illisibles ; si elle est PERDUE en prod, ils sont irrécupérables et doivent
# être re-saisis club par club — en garder une copie hors serveur.
# Générer : openssl rand -base64 32
AI_SECRETS_KEY=

# --- Stripe (paiement en ligne des factures depuis le portail) ---
# Tableau de bord Stripe → Développeurs → Clés API → « Clé secrète » (sk_live_… ou sk_test_…).
# Ne jamais exposer cette clé côté front.
# STRIPE_SECRET_KEY=
# Secret du webhook Stripe (événements payment_intent.*), à configurer sur le
# endpoint <API_PUBLIC_URL>/webhooks/stripe depuis le dashboard.
# STRIPE_WEBHOOK_SECRET=

# --- Tâches planifiées liées aux paiements (interrupteurs d'urgence) ---
# Les deux sont ABSENTES par défaut, et c'est le comportement voulu : les jobs
# tournent. Ne les poser qu'en cas d'incident, et surtout PENSER À LES RETIRER —
# un job de prélèvement laissé désactivé accumule des échéances en silence.
#
# Coupe le prélèvement quotidien des échéances (8h, Indian/Reunion).
# PAYMENT_SCHEDULE_CRON_DISABLED=true
# Coupe le balayage HORAIRE des frais Stripe (à :15). C'est par lui que la
# plupart des frais sont récupérés — carte comprise, la balance transaction
# n'existant généralement pas encore au moment du webhook. Sans lui, le
# résultat comptable des clubs reste surévalué du total de leurs frais.
# STRIPE_FEES_SWEEP_DISABLED=true
# Coupe le rapprochement quotidien des remboursements (9h30, Indian/Reunion).
# Sans lui, un webhook charge.refunded manqué laisse de l'argent parti du
# compte du club sans aucune trace en base — le pire état possible.
# STRIPE_REFUND_RECONCILE_DISABLED=true
# Coupe le balayage quotidien des seuils de stock boutique (7h, Indian/Reunion).
# Aucune alerte de réapprovisionnement ne partira : les clubs tomberont en
# rupture sans être prévenus, et rien d'autre ne le signalera. Le job journalise
# un WARN à chaque passage tant que l'interrupteur est posé — c'est la seule
# trace qu'il existe.
# SHOP_STOCK_SWEEP_DISABLED=true

# OAuth Google (optionnel en dev ; obligatoire pour le bouton « Google »)
# GOOGLE_REDIRECT_URI doit correspondre à la console Google (callback HTTP API)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Partie locale de l’adresse From (domaine = FQDN enregistré par club)
MAIL_FROM_LOCAL_PART=noreply

# Sous-domaines « marque ClubFlow » sans domaine propre du club (FQDN = {slug}.{suffixe}).
# Ex. mail.clubflow.fr → club slug sksr donne sksr.mail.clubflow.fr. Zone DNS du suffixe = opérateur.
# Laisser vide pour désactiver l’offre côté admin.
# CLUBFLOW_HOSTED_MAIL_DOMAIN=mail.clubflow.fr

# --- Site vitrine public (apps/vitrine) ---
# URL cible du webhook Next.js pour l'invalidation ISR. Défaut : localhost:5175.
# VITRINE_REVALIDATE_URL=http://localhost:5175/api/revalidate
# Secret partagé (même valeur dans apps/vitrine/.env). Sans ce secret, l'API
# skip silencieusement le webhook (le cache ISR expire à 60s par défaut).
# VITRINE_REVALIDATE_SECRET=change-me-revalidate
# URL publique de la vitrine utilisée par les boutons « Éditer sur le site ↗ ».
# Défaut : http://localhost:5175. Mettre le domaine prod (ex. https://demo.clubflow.fr).
# VITRINE_PUBLIC_URL=http://localhost:5175
