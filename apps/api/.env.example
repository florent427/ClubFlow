# Base — copier vers .env et ajuster
DATABASE_URL="postgresql://user:pass@localhost:5432/clubflow"

# Club unique MVP (UUID). Après `npm run db:seed`, copier la valeur affichée « CLUB_ID=… ».
CLUB_ID=""

JWT_SECRET="change-me"
JWT_EXPIRES_IN="15m"
REFRESH_SECRET="change-me-too"

# Admin (origines CORS, séparées par des virgules en prod)
ADMIN_WEB_ORIGIN="http://localhost:5173"

# Port API (même valeur en local et sur serveur si reverse-proxy)
PORT=3000

# --- E-mail : relais SMTP (Mailpit, Postfix, OVH, etc.) ---
#
# Prod (API sur hôte + Postfix profile relay) — après : docker compose --profile relay up -d db postfix
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=2525
#   SMTP_SECURE=false
# IP publique utilisée par Postfix pour sortir vers Internet (alignement SPF MVP quand SMTP_DNS_SPF_CHECK=true).
# SMTP_PUBLIC_EGRESS_IP=203.0.113.10
# true = refreshDomain exige un SPF TXT avec ip4: égal à SMTP_PUBLIC_EGRESS_IP (voir runbook + spec).
# SMTP_DNS_SPF_CHECK=false
# Adresse de collecte DMARC (RUA), optionnel — si défini, l’admin reçoit une suggestion TXT _dmarc.
# SMTP_DMARC_RUA_EMAIL=dmarc@example.com
# Bloc SPF suggéré à l’enregistrement du domaine : v=spf1 ip4:<SMTP_PUBLIC_EGRESS_IP> ~all (phase test ; passer à -all quand l’IP est stable).
#
# Test local rapide :
#   docker run -d --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit
#
# --- Brevo (test livraison réelle, ex. Gmail) ---
# Console : https://app.brevo.com → « SMTP & API » → générer / copier la **clé SMTP** (ce n’est ni le mot de passe du compte ni la clé API REST v3).
# **SMTP_USER** : l’adresse e-mail d’identification SMTP affichée par Brevo (souvent la même que ton compte).
# **Expéditeur** : le domaine ou l’adresse « From » utilisée par ClubFlow doit être **autorisée / vérifiée** dans Brevo (Senders, domaines, DKIM).
# Nodemailer : port 587 = STARTTLS → SMTP_SECURE=false (voir smtp-mail.transport.ts).
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=ton-login-smtp@example.com
# SMTP_PASS=xsmtpsib-xxxxxxxx
#
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=

# Si « false » : le bouton « Vérifier » ne passera pas le domaine en VERIFIED (mode strict, rare).
# Par défaut les domaines sont acceptés après vérif : la délivrabilité (SPF/DKIM) est à votre charge côté DNS/serveur.
SMTP_AUTO_VERIFY_DOMAIN=true

# URL publique de l’API (optionnel, pour d’autres modules)
API_PUBLIC_URL=http://localhost:3000

# Portail membre (liens e-mail de vérification, redirect OAuth)
MEMBER_PORTAL_ORIGIN=http://localhost:5174

# Jetons de vérification e-mail (HMAC) — à changer en prod
EMAIL_VERIFICATION_SECRET="change-me-email-verify"

# OAuth Google (optionnel en dev ; obligatoire pour le bouton « Google »)
# GOOGLE_REDIRECT_URI doit correspondre à la console Google (callback HTTP API)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Partie locale de l’adresse From (domaine = FQDN enregistré par club)
MAIL_FROM_LOCAL_PART=noreply

# Sous-domaines « marque ClubFlow » sans domaine propre du club (FQDN = {slug}.{suffixe}).
# Ex. mail.clubflow.fr → club slug sksr donne sksr.mail.clubflow.fr. Zone DNS du suffixe = opérateur.
# Laisser vide pour désactiver l’offre côté admin.
# CLUBFLOW_HOSTED_MAIL_DOMAIN=mail.clubflow.fr
