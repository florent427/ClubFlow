  @@unique([clubId, emailNormalized])
  @@index([clubId])
}

// --- Phase G : Comptabilité (écritures) + stubs Subventions / Sponsoring ---

enum AccountingEntryKind {
  INCOME
  EXPENSE
  /// Contributions volontaires en nature (PCG 870/871). Neutre au résultat
  /// mais comptabilisé séparément pour audit / bilan moral.
  IN_KIND
  /// Virement interne (ex. banque → caisse), non impactant P&L.
  TRANSFER
}

/// Statut d'une écriture comptable dans le cycle de vie partie double.
/// DRAFT = brouillon utilisateur, NEEDS_REVIEW = post-OCR en attente validation,
/// POSTED = validée et comptabilisée, LOCKED = mois clôturé (immutable),
/// CANCELLED = annulée via contre-passation.
enum AccountingEntryStatus {
  DRAFT
  NEEDS_REVIEW
  POSTED
  LOCKED
  CANCELLED
}

/// Origine d'une écriture — trace d'où elle vient pour audit et UX.
enum AccountingEntrySource {
  /// Saisie manuelle au formulaire par un trésorier / admin.
  MANUAL
  /// Générée via pipeline OCR + IA (OpenRouter vision).
  OCR_AI
  /// Hook automatique sur encaissement de cotisation (Invoice PAID).
  AUTO_MEMBER_PAYMENT
  /// Hook automatique sur versement de subvention (GrantInstallment).
  AUTO_SUBSIDY
  /// Hook automatique sur versement de sponsoring (SponsorshipInstallment).
  AUTO_SPONSORSHIP
  /// Hook automatique sur vente boutique (ShopOrder payée).
  AUTO_SHOP
  /// Contre-passation automatique sur credit note Invoice.
  AUTO_REFUND
  /// Split frais Stripe (512 net / 627 frais / 411 contrepartie).
  AUTO_STRIPE_FEES
}

/// Côté comptable d'une ligne d'écriture. AUTO = dérivé à la création
/// depuis (accountKind, entryKind). DEBIT/CREDIT = forcé manuellement
/// (cas tordus : contre-passation, immobilisations, écritures d'ajustement).
enum AccountingLineSide {
  AUTO
  DEBIT
  CREDIT
}

model AccountingEntry {
  id                       String                @id @default(uuid())
  clubId                   String
  kind                     AccountingEntryKind
  /// Statut dans le workflow partie double. Backfill = POSTED.
  status                   AccountingEntryStatus @default(POSTED)
  /// Origine de l'écriture. Backfill : AUTO_MEMBER_PAYMENT si paymentId
  /// non null, sinon MANUAL.
  source                   AccountingEntrySource @default(MANUAL)
  label                    String
  /// Montant TTC dénormalisé = somme des débits OU crédits (selon side).
  /// Conservé pour le listing rapide sans jointure lines.
  amountCents              Int
  /// Somme TVA sur l'écriture (si `Club.vatMode != NONE`, sinon null).
  vatTotalCents            Int?
  paymentId                String?
  /// Rattachement analytique optionnel à un ClubProject. Null = écriture
  /// générale club. Permet de projeter un P&L par projet une fois le
  /// module compta activé.
  projectId                String?
  /// Si `source = AUTO_SUBSIDY`, lien vers la subvention concernée.
  subsidyId                String?
  /// Si `source = AUTO_SPONSORSHIP`, lien vers le deal concerné.
  sponsorshipDealId        String?
  /// Si `source = OCR_AI`, trace l'extraction IA qui a généré cette entry.
  extractionId             String?
  /// Contre-passation : si cette entry est une contre-passation, pointe vers
  /// l'entry originale. Si cette entry a été contre-passée, la relation inverse
  /// `contraEntryOf` liste les contre-passations qui la visent.
  contraEntryId            String?
  /// Timestamp de verrouillage (mois clôturé). Écriture immutable sauf
  /// création d'une contre-passation datée d'un mois ouvert.
  lockedAt                 DateTime?
  /// Soft cancel : si cancelledAt non null, l'écriture est annulée (via
  /// contre-passation typiquement). Jamais purgée (rétention 10 ans).
  cancelledAt              DateTime?
  cancelledByUserId        String?
  createdByUserId          String?
  /// Compte financier de contrepartie (banque/caisse/transit). Null pour
  /// les entries legacy créées avant la migration multi-comptes — le code
  /// tolère null en fallback sur la banque par défaut du club.
  financialAccountId       String?
  /// Marqueur "écriture consolidée" : indique que des lignes ont été
  /// fusionnées par compte (cas note de resto où 6 articles → 1 ligne
  /// 625700 Réceptions). Null = écriture détaillée standard.
  consolidatedAt           DateTime?
  /// Snapshot JSON des lignes/allocations pré-consolidation. Permet
  /// `unconsolidate` pour restaurer la granularité d'origine.
  preConsolidationSnapshot Json?
  occurredAt               DateTime              @default(now())
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @default(now()) @updatedAt

  club             Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  payment          Payment?              @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  project          ClubProject?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  subsidy          GrantApplication?     @relation(fields: [subsidyId], references: [id], onDelete: SetNull)
  sponsorship      SponsorshipDeal?      @relation(fields: [sponsorshipDealId], references: [id], onDelete: SetNull)
  extraction       AccountingExtraction? @relation(fields: [extractionId], references: [id], onDelete: SetNull)
  contraEntry      AccountingEntry?      @relation("AccountingEntryContra", fields: [contraEntryId], references: [id], onDelete: SetNull)
  contraEntryOf    AccountingEntry[]     @relation("AccountingEntryContra")
  financialAccount ClubFinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)

  lines                   AccountingEntryLine[]
  documents               AccountingDocument[]
  auditLogs               AccountingAuditLog[]
  grantInstallments       GrantInstallment[]
  sponsorshipInstallments SponsorshipInstallment[]

  @@index([clubId, occurredAt])
  @@index([clubId, projectId])
  @@index([clubId, status])
  @@index([clubId, source])
  @@index([clubId, financialAccountId])
}

/// Cycle de vie complet d'une demande de subvention :
/// DRAFT → REQUESTED (envoyée) → GRANTED (accordée) → PARTIALLY_PAID
/// (au moins 1 tranche reçue) → PAID (toutes tranches reçues) → REPORTED
/// (rapport de justification soumis) → SETTLED (dossier soldé).
/// Branches terminales : REJECTED, ARCHIVED.
enum GrantApplicationStatus {
  DRAFT
  REQUESTED
  GRANTED
  PARTIALLY_PAID
  PAID
  REPORTED
  SETTLED
  REJECTED
  ARCHIVED
}

enum GrantDocumentKind {
  APPLICATION
  DECISION
  INVOICE
  REPORT
  OTHER
}

model GrantApplication {
  id                   String                 @id @default(uuid())
  clubId               String
  title                String
  /// Organisme financeur (libre). Ex : "Mairie de Saint-Denis", "FDVA",
  /// "CNDS", "Conseil Départemental 93".
  fundingBody          String?
  status               GrantApplicationStatus @default(DRAFT)
  /// Montant demandé initial (avant décision).
  requestedAmountCents Int?
  /// Montant effectivement accordé après décision.
  grantedAmountCents   Int?
  /// Conservé pour backward compat (ancien champ `amountCents`). Alias
  /// fonctionnel de `grantedAmountCents` pour les dossiers legacy.
  amountCents          Int?
  projectId            String?
  startsAt             DateTime?
  endsAt               DateTime?
  /// Date limite de dépôt du rapport / justification d'emploi des fonds.
  reportDueAt          DateTime?
  /// Date effective de soumission du rapport.
  reportSubmittedAt    DateTime?
  notes                String?
  createdByUserId      String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  club         Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  project      ClubProject?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  installments GrantInstallment[]
  documents    GrantDocument[]
  entries      AccountingEntry[]

  @@index([clubId])
  @@index([clubId, status])
  @@index([clubId, reportDueAt])
}

model GrantInstallment {
  id                  String    @id @default(uuid())
  grantId             String
  clubId              String
  expectedAmountCents Int
  receivedAmountCents Int?
  expectedAt          DateTime?
  receivedAt          DateTime?
  paymentId           String?
  accountingEntryId   String?
  notes               String?
  createdAt           DateTime  @default(now())

  grant   GrantApplication @relation(fields: [grantId], references: [id], onDelete: Cascade)
  payment Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  entry   AccountingEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: SetNull)

  @@index([grantId])
  @@index([clubId])
}

model GrantDocument {
  id           String            @id @default(uuid())
  grantId      String
  clubId       String
  mediaAssetId String
  kind         GrantDocumentKind @default(OTHER)
  createdAt    DateTime          @default(now())

  grant      GrantApplication @relation(fields: [grantId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset       @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([grantId, mediaAssetId])
  @@index([clubId])
}

/// Statut d'un deal de sponsoring. DRAFT = préparé, ACTIVE = signé / en
/// cours, CLOSED = échu / soldé, CANCELLED = annulé.
enum SponsorshipDealStatus {
  DRAFT
  ACTIVE
  CLOSED
  CANCELLED
}

/// Type de sponsoring : CASH (versements en monnaie) ou IN_KIND
/// (contributions en nature : matériel, prestations, locaux).
/// IN_KIND génère des écritures sur les comptes PCG 870/871.
enum SponsorshipKind {
  CASH
  IN_KIND
}

enum SponsorshipDocumentKind {
  CONTRACT
  INVOICE
  RECEIPT
  OTHER
}

model SponsorshipDeal {
  id                String                @id @default(uuid())
  clubId            String
  sponsorName       String
  kind              SponsorshipKind       @default(CASH)
  /// Valeur totale attendue (cash) OU valorisation estimée (nature).
  valueCents        Int?
  /// Conservé pour backward compat (ancien champ `amountCents`). Alias de
  /// `valueCents` pour les deals legacy.
  amountCents       Int?
  /// Description lisible des apports nature (ex : "20 T-shirts + 5 cartons
  /// de gourdes isothermes"). Requis si kind = IN_KIND.
  inKindDescription String?
  status            SponsorshipDealStatus @default(DRAFT)
  projectId         String?
  /// Sponsor persisté comme Contact du club (optionnel).
  contactId         String?
  startsAt          DateTime?
  endsAt            DateTime?
  notes             String?
  createdByUserId   String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  club         Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  project      ClubProject?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contact      Contact?                 @relation(fields: [contactId], references: [id], onDelete: SetNull)
  installments SponsorshipInstallment[]
  documents    SponsorshipDocument[]
  entries      AccountingEntry[]

  @@index([clubId])
  @@index([clubId, status])
}

model SponsorshipInstallment {
  id                  String    @id @default(uuid())
  dealId              String
  clubId              String
  expectedAmountCents Int
  receivedAmountCents Int?
  expectedAt          DateTime?
  receivedAt          DateTime?
  paymentId           String?
  accountingEntryId   String?
  createdAt           DateTime  @default(now())

  deal    SponsorshipDeal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  payment Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  entry   AccountingEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([clubId])
}

model SponsorshipDocument {
  id           String                  @id @default(uuid())
  dealId       String
  clubId       String
  mediaAssetId String
  kind         SponsorshipDocumentKind @default(OTHER)
  createdAt    DateTime                @default(now())

  deal       SponsorshipDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset      @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([dealId, mediaAssetId])
  @@index([clubId])
}

enum ClubSurveyStatus {
  DRAFT
  OPEN
  CLOSED
}

model ClubAnnouncement {
  id           String    @id @default(uuid())
  clubId       String
  authorUserId String
  title        String
  body         String
  pinned       Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([clubId, publishedAt])
  @@index([clubId, pinned])
}

model ClubSurvey {
  id             String           @id @default(uuid())
  clubId         String
  authorUserId   String
  title          String
  description    String?
  status         ClubSurveyStatus @default(DRAFT)
  multipleChoice Boolean          @default(false)
  allowAnonymous Boolean          @default(false)
  publishedAt    DateTime?
  closesAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  options   ClubSurveyOption[]
  responses ClubSurveyResponse[]

  @@index([clubId, status])
}

model ClubSurveyOption {
  id        String   @id @default(uuid())
  surveyId  String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  survey    ClubSurvey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  responses ClubSurveyResponse[]

  @@index([surveyId])
}

model ClubSurveyResponse {
  id        String   @id @default(uuid())
  surveyId  String
  optionId  String
  memberId  String?
  contactId String?
  createdAt DateTime @default(now())

  survey ClubSurvey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  option ClubSurveyOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([surveyId, memberId, optionId])
  @@unique([surveyId, contactId, optionId])
  @@index([surveyId])
}

enum ClubEventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum ClubEventRegistrationStatus {
  REGISTERED
  WAITLISTED
  CANCELLED
}

model ClubEvent {
  id                       String          @id @default(uuid())
  clubId                   String
  /// Rattachement optionnel à un ClubProject (un projet peut regrouper N
  /// events datés — ex. « Gala 2026 » a une soirée + une répétition
  /// rattachées). Null = event autonome (cours hebdo, stage simple).
  projectId                String?
  title                    String
  description              String?
  location                 String?
  startsAt                 DateTime
  endsAt                   DateTime
  capacity                 Int?
  registrationOpensAt      DateTime?
  registrationClosesAt     DateTime?
  priceCents               Int?
  status                   ClubEventStatus @default(DRAFT)
  publishedAt              DateTime?
  allowContactRegistration Boolean         @default(false)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  project       ClubProject?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  registrations ClubEventRegistration[]
  attachments   ClubEventAttachment[]

  @@index([clubId, startsAt])
  @@index([clubId, status])
  @@index([projectId])
}

model ClubEventRegistration {
  id           String                      @id @default(uuid())
  eventId      String
  memberId     String?
  contactId    String?
  status       ClubEventRegistrationStatus @default(REGISTERED)
  registeredAt DateTime                    @default(now())
  cancelledAt  DateTime?
  note         String?

  event ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@unique([eventId, contactId])
  @@index([eventId, status])
}

/// Pièces jointes d'un événement (PDF, images…). Fichier stocké sur disque, métadonnées en base.
model ClubEventAttachment {
  id          String   @id @default(uuid())
  eventId     String
  fileName    String
  mimeType    String
  sizeBytes   Int
  storagePath String // chemin absolu sur disque — géré par EventAttachmentsService
  createdAt   DateTime @default(now())

  event ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ShopOrderStatus {
  PENDING
  PAID
  CANCELLED
}

model ShopProduct {
  id          String   @id @default(uuid())
  clubId      String
  sku         String?
  name        String
  description String?
  imageUrl    String?
  priceCents  Int
  stock       Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderLines ShopOrderLine[]

  @@index([clubId, active])
}

model ShopOrder {
  id         String          @id @default(uuid())
  clubId     String
  memberId   String?
  contactId  String?
  status     ShopOrderStatus @default(PENDING)
  totalCents Int
  note       String?         @db.VarChar(500)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  paidAt     DateTime?

  lines ShopOrderLine[]

  @@index([clubId, status])
  @@index([memberId])
  @@index([contactId])
}

model ShopOrderLine {
  id             String @id @default(uuid())
  orderId        String
  productId      String
  quantity       Int
  unitPriceCents Int
  label          String

  order   ShopOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product ShopProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model BlogPost {
  id            String         @id @default(uuid())
  clubId        String
  authorUserId  String
  slug          String
  title         String
  excerpt       String?        @db.VarChar(500)
  body          String
  coverImageUrl String?
  status        BlogPostStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([clubId, slug])
  @@index([clubId, status, publishedAt])
}

// --- Phase H : Projet d'adhésion (panier famille × saison) ---

enum MembershipCartStatus {
  /// Panier ouvert, modifiable librement. Un seul OPEN par (familyId, clubSeasonId).
  OPEN
  /// Panier validé → facture émise + email payeur envoyé. Immuable.
  VALIDATED
  /// Panier abandonné par le payeur (ou annulé par l'admin). Aucune facture générée.
  CANCELLED
}

/// Panier/projet d'adhésion d'une famille pour une saison. Accumule les items (membres + produit + licence + rythme + remises)
/// avant d'émettre la facture à la validation. Pas d'impact comptable tant que status != VALIDATED.
model MembershipCart {
  id              String               @id @default(uuid())
  clubId          String
  familyId        String
  clubSeasonId    String
  payerContactId  String?
  payerMemberId   String?
  status          MembershipCartStatus @default(OPEN)
  validatedAt     DateTime?
  invoiceId       String?              @unique
  cancelledReason String?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  club         Club                        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  family       Family                      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  clubSeason   ClubSeason                  @relation(fields: [clubSeasonId], references: [id], onDelete: Cascade)
  payerContact Contact?                    @relation("CartPayerContact", fields: [payerContactId], references: [id], onDelete: SetNull)
  payerMember  Member?                     @relation("CartPayerMember", fields: [payerMemberId], references: [id], onDelete: SetNull)
  invoice      Invoice?                    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  items        MembershipCartItem[]
  pendingItems MembershipCartPendingItem[]

  @@index([clubId, status])
  @@index([familyId, clubSeasonId, status])
}

/// Item du panier = adhésion individuelle d'un membre pour la saison courante du cart.
/// Une ligne par membre, produit auto-sélectionné par âge (ou null si aucun produit ne matche).
model MembershipCartItem {
  id                        String                    @id @default(uuid())
  cartId                    String
  memberId                  String
  membershipProductId       String?
  billingRhythm             SubscriptionBillingRhythm @default(ANNUAL)
  hasExistingLicense        Boolean                   @default(false)
  existingLicenseNumber     String?
  exceptionalDiscountCents  Int                       @default(0)
  exceptionalDiscountReason String?
  /// true si aucun produit n'a matché l'âge du membre — admin doit assigner manuellement.
  requiresManualAssignment  Boolean                   @default(false)
  /// CSV des IDs de MembershipOneTimeFee forcés (override des autoApply défaut).
  /// Convention : si null → utiliser la liste des fees `autoApply=true` du club.
  /// Si présent → utiliser exactement cette liste.
  oneTimeFeeOverrideIdsCsv  String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  cart    MembershipCart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  member  Member             @relation(fields: [memberId], references: [id], onDelete: Restrict)
  product MembershipProduct? @relation(fields: [membershipProductId], references: [id], onDelete: SetNull)

  /// Permet plusieurs formules pour un même membre (ex Karaté + Cross
  /// Training). L'unicité est sur le triplet (cart, member, produit) —
  /// on évite seulement les doublons exacts. Les anciens code-paths qui
  /// supposaient "1 ligne par membre" doivent agréger via `findFirst`
  /// ou `findMany` au lieu de `findUnique`.
  @@unique([cartId, memberId, membershipProductId])
  @@index([cartId])
  @@index([memberId])
}

/// Inscription "en attente" dans un cart — une personne (Contact ou enfant
/// à créer) qui veut adhérer mais dont la fiche `Member` n'est PAS encore
/// créée. Évite les Members fantômes si le payeur abandonne le projet
/// d'adhésion.
///
/// Stratégie : snapshot complet des données identitaires + array des
/// formules choisies. À la validation du cart, chaque PendingItem est
/// transformé en Member réel + autant de `MembershipCartItem` que de
/// formules sélectionnées. `convertedToMemberId` trace la conversion
/// pour l'audit (NULL = abandon).
///
/// Multi-formules : `membershipProductIds` est un array — Samantha peut
/// s'inscrire à Karaté Adultes ET Cross Training en une seule action.
model MembershipCartPendingItem {
  id                   String                    @id @default(uuid())
  cartId               String
  /// Snapshot identité (au moment de la sélection)
  firstName            String
  lastName             String
  civility             MemberCivility
  birthDate            DateTime
  /// Email snapshot (du Contact payeur, hérité). Sert au check unicité
  /// au moment de la finalisation.
  email                String
  /// Si la personne est déjà un Contact du club (cas auto-inscription
  /// adulte). Null pour un enfant ajouté par le payeur (pas de Contact
  /// préalable).
  contactId            String?
  /// IDs de MembershipProduct sélectionnés. Toujours ≥ 1.
  membershipProductIds String[]
  billingRhythm        SubscriptionBillingRhythm @default(ANNUAL)
  /// FK forte vers le Member créé à la validation. Null = pas encore
  /// converti (cart pas encore validé OU abandon).
  convertedToMemberId  String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  cart            MembershipCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  contact         Contact?       @relation("PendingItemContact", fields: [contactId], references: [id], onDelete: SetNull)
  convertedMember Member?        @relation("PendingItemConvertedMember", fields: [convertedToMemberId], references: [id], onDelete: SetNull)

  @@unique([cartId, email, firstName, lastName])
  @@index([cartId])
  @@index([contactId])
}

// ============================================================================
// Vitrine publique (apps/vitrine) — pages, articles, annonces, galerie, médias
// ============================================================================

enum VitrinePageStatus {
  DRAFT
  PUBLISHED
}

enum VitrineArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Canal de publication d'un VitrineArticle : « actualités » (brèves du
/// quotidien affichées sur /actualites) ou « blog » (articles de fond sur
/// /blog). Les deux canaux partagent la même structure (SEO, catégories,
/// commentaires, IA), ils sont juste filtrés sur le site public et
/// regroupés dans deux onglets côté admin.
enum VitrineArticleChannel {
  NEWS
  BLOG
}

enum MediaAssetKind {
  IMAGE
  DOCUMENT
  OTHER
}

/// Page vitrine — un enregistrement par (clubId, slug).
/// `sectionsJson` = tableau ordonné [{ id, type, props }] rendu par
/// `VitrinePageRenderer` côté Next.js. Permet une migration future vers
/// GrapeJS sans changer le schéma (même format JSON).
model VitrinePage {
  id             String            @id @default(uuid())
  clubId         String
  slug           String
  templateKey    String            @default("sksr-v1")
  status         VitrinePageStatus @default(PUBLISHED)
  seoTitle       String?
  seoDescription String?
  seoOgImageId   String?
  sectionsJson   Json
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  club       Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  seoOgImage MediaAsset?           @relation("VitrinePageOgImage", fields: [seoOgImageId], references: [id], onDelete: SetNull)
  revisions  VitrinePageRevision[]

  @@unique([clubId, slug])
  @@index([clubId, status])
}

/// Révision historique dune `VitrinePage` — permet undo/redo côté admin.
/// Plafonnée à ~50 rangées par page (nettoyage programmatique côté service).
model VitrinePageRevision {
  id             String   @id @default(uuid())
  pageId         String
  sectionsJson   Json
  seoTitle       String?
  seoDescription String?
  authorUserId   String?
  createdAt      DateTime @default(now())

  page VitrinePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
}

/// État de génération IA d'un article vitrine.
/// - NONE : article créé manuellement (pas de génération)
/// - PENDING : génération IA en cours en arrière-plan
/// - DONE : génération terminée avec succès
/// - FAILED : génération échouée (voir generationError)
enum VitrineArticleGenerationStatus {
  NONE
  PENDING
  DONE
  FAILED
}

/// Statut d'un commentaire sur un article vitrine après modération.
/// - PENDING : vient d'être soumis, modération IA en cours
/// - APPROVED : IA a jugé OK → visible sur la vitrine publique
/// - NEEDS_REVIEW : IA a flagué pour relecture humaine (admin doit trancher)
/// - REJECTED : IA ou admin a rejeté (non visible public)
/// - SPAM : spam détecté (non visible public + bloqué futur)
enum VitrineCommentStatus {
  PENDING
  APPROVED
  NEEDS_REVIEW
  REJECTED
  SPAM
}

/// Catégorie d'article vitrine (type WordPress). Un article peut avoir
/// plusieurs catégories via la table de jointure implicite Prisma.
model VitrineCategory {
  id          String   @id @default(uuid())
  clubId      String
  slug        String
  name        String
  description String?
  /// Couleur hex pour le badge visuel (#RRGGBB). Si null → couleur par défaut.
  color       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club     Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  articles VitrineArticle[] @relation("VitrineArticleCategories")

  @@unique([clubId, slug])
  @@index([clubId, sortOrder])
}

/// Commentaire sur un article vitrine (public, soumis par un visiteur).
/// Modéré automatiquement par IA avant affichage.
model VitrineComment {
  id               String               @id @default(uuid())
  articleId        String
  authorName       String
  authorEmail      String
  body             String
  ipAddress        String?
  userAgent        String?
  status           VitrineCommentStatus @default(PENDING)
  /// Score IA 0.0 (rejeté) → 1.0 (parfait). Null = pas encore modéré.
  aiScore          Float?
  /// Catégorie attribuée par l'IA (constructive, off-topic, offensive, spam, insulting, other).
  aiCategory       String?
  /// Raison lisible de la décision IA (affichée à l'admin).
  aiReason         String?
  /// Id user admin qui a review manuellement (si applicable).
  reviewedByUserId String?
  reviewedAt       DateTime?

  /// Réponse de l'admin (ou générée par IA, validée par admin avant publication).
  /// Null = pas de réponse publiée.
  adminReplyBody       String?
  /// Nom à afficher pour la réponse (ex. "Sensei Tanaka", "L'équipe SKSR", "Direction").
  adminReplyAuthorName String?
  adminReplyAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article VitrineArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, status, createdAt])
  @@index([status, createdAt])
}

/// Article vitrine — distinct du BlogPost (lui réservé aux membres connectés).
///
/// `bodyJson` = `{ format: 'html', html: '...' }` (WYSIWYG Tiptap) OU
/// `['para1', 'para2']` (ancien format paragraphes, rétrocompatible lecture).
model VitrineArticle {
  id           String                @id @default(uuid())
  clubId       String
  slug         String
  title        String
  excerpt      String?
  bodyJson     Json
  coverImageId String?
  status       VitrineArticleStatus  @default(DRAFT)
  /// Canal : actualité courte (NEWS) ou article de fond (BLOG). Filtre
  /// les deux listes publiques /actualites et /blog, et groupe les deux
  /// onglets dans l'admin — création, SEO, catégories, commentaires,
  /// génération IA et tampon acquitté identiques quelle que soit la valeur.
  channel      VitrineArticleChannel @default(BLOG)
  publishedAt  DateTime?
  authorUserId String?
  /// Épinglé en tête de la liste de son canal (/actualites ou /blog).
  pinned       Boolean               @default(false)
  /// Ordre manuel (drag-and-drop admin). Plus petit = plus haut. Les
  /// articles épinglés sont triés entre eux par sortOrder avant les non
  /// épinglés (eux-mêmes triés par publishedAt desc).
  sortOrder    Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  // --- SEO ---
  seoTitle        String? // <title> balise, ≤ 60 chars recommandé
  seoDescription  String? // <meta name="description">, 150-160 chars
  seoKeywords     String[] @default([]) // LSI / mots-clés cibles
  seoH1           String? // H1 de l'article (si différent du titre)
  seoFaqJson      Json? // [{question, answer}] pour schema.org FAQPage
  seoCanonicalUrl String? // URL canonical si dupliquée ailleurs
  seoNoindex      Boolean  @default(false)
  seoOgImageId    String? // Image Open Graph (partage sociaux). Si null → coverImageId.
  coverImageAlt   String? // alt de l'image de couverture

  // --- Génération IA en arrière-plan ---
  generationStatus    VitrineArticleGenerationStatus @default(NONE)
  generationProgress  String? // libellé courant (ex. "Génération du texte…", "Images 2/4")
  generationError     String? // message d'erreur si FAILED
  generationWarnings  String[]                       @default([]) // avertissements non-bloquants (ex. image gen failed)
  generationStartedAt DateTime?
  generationEndedAt   DateTime?

  club       Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  coverImage MediaAsset?       @relation("VitrineArticleCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  seoOgImage MediaAsset?       @relation("VitrineArticleOgImage", fields: [seoOgImageId], references: [id], onDelete: SetNull)
  categories VitrineCategory[] @relation("VitrineArticleCategories")
  comments   VitrineComment[]

  @@unique([clubId, slug])
  @@index([clubId, status, publishedAt])
  @@index([clubId, channel, status, publishedAt])
  @@index([clubId, generationStatus])
}

/// Annonce courte affichée sur la vitrine (≠ ClubAnnouncement membre).
model VitrineAnnouncement {
  id          String    @id @default(uuid())
  clubId      String
  title       String
  body        String
  pinned      Boolean   @default(false)
  /// Ordre manuel (drag-and-drop admin). Plus petit = plus haut. Les
  /// annonces épinglées sont triées entre elles par sortOrder avant les non
  /// épinglées.
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, publishedAt])
}

/// Photo de galerie publique — pointée vers un MediaAsset.
model VitrineGalleryPhoto {
  id           String   @id @default(uuid())
  clubId       String
  mediaAssetId String
  caption      String?
  category     String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  club       Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation("VitrineGalleryPhotoAsset", fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([clubId, category, sortOrder])
}

/// Actif média générique (image, document) — scope par club, propriétaire
/// polymorphe (`ownerKind` + `ownerId`). Remplace progressivement
/// `ClubEventAttachment` en Phase 2.
model MediaAsset {
  id               String         @id @default(uuid())
  clubId           String
  kind             MediaAssetKind @default(IMAGE)
  ownerKind        String?
  ownerId          String?
  fileName         String
  mimeType         String
  sizeBytes        Int
  storagePath      String
  publicUrl        String
  widthPx          Int?
  heightPx         Int?
  /// SHA-256 hexadécimal du fichier stocké. Utilisé pour la déduplication
  /// des reçus comptables et la détection de doublons cross-modules.
  /// Nullable pour permettre un backfill progressif des assets existants.
  sha256           String?
  uploadedByUserId String?
  createdAt        DateTime       @default(now())

  club                  Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  galleryPhotos         VitrineGalleryPhoto[]  @relation("VitrineGalleryPhotoAsset")
  articleCovers         VitrineArticle[]       @relation("VitrineArticleCover")
  articleOgImages       VitrineArticle[]       @relation("VitrineArticleOgImage")
  ogPages               VitrinePage[]          @relation("VitrinePageOgImage")
  projectPosters        ClubProject[]          @relation("ProjectPoster")
  projectCovers         ClubProject[]          @relation("ProjectCover")
  projectLiveItems      ProjectLiveItem[]      @relation("ProjectLiveItemMedia")
  accountingExtractions AccountingExtraction[]
  accountingDocuments   AccountingDocument[]
  grantDocuments        GrantDocument[]
  sponsorshipDocuments  SponsorshipDocument[]

  @@index([clubId, ownerKind, ownerId])
  @@index([clubId, sha256])
}

// ============================================================================
// Module PROJETS  (v1 — cf. plan glowing-bubbling-llama.md)
// ----------------------------------------------------------------------------
// ClubProject + sections built-in (Bénévolat/Admin/Com/Live + Accounting r-o),
// phases LIVE multiples, contributeurs polymorphes, items (photos/vidéos)
// modérés IA puis humain, comptes-rendus IA, listes de diffusion RGPD.
// ============================================================================

enum ProjectStatus {
  PLANNED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ProjectLivePhaseState {
  UPCOMING
  LIVE
  CLOSED
}

enum ProjectSectionKind {
  VOLUNTEERS
  ADMIN
  COMMUNICATION
  LIVE
  ACCOUNTING
  CUSTOM
}

enum ProjectContributorRole {
  CONTRIBUTOR
}

enum ProjectLiveItemKind {
  PHOTO
  VIDEO
  /// Soumission texte libre (témoignage, caption, anecdote). `textContent`
  /// est renseigné, `mediaAssetId` reste null. Utilisé pour enrichir les
  /// comptes-rendus sans nécessiter une photo ou une vidéo.
  TEXT
}

enum ProjectLiveItemAiDecision {
  PENDING
  APPROVED
  REJECTED
  ERROR
}

enum ProjectLiveItemHumanDecision {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectLiveItemPublication {
  NONE
  VITRINE_NEWS
  VITRINE_BLOG
  MEMBER_ANNOUNCEMENT
}

enum ProjectReportTemplate {
  COMPETITIF
  FESTIF
  BILAN
  /// Génération avec prompt personnalisé fourni par l'admin (ex. « fais un
  /// compte-rendu des performances de nos athlètes »). Le champ `customPrompt`
  /// de `ProjectReport` est alors renseigné et remplace le preset de ton.
  CUSTOM
}

enum ProjectReportStatus {
  DRAFT
  PUBLISHED
}

enum DistributionMailStatus {
  DRAFT
  SENT
  FAILED
  UNSUBSCRIBED
}

/// Événement / Projet long-terme (au-delà d'un ClubEvent simple).
/// Créé avec 4 sections built-in (VOLUNTEERS, ADMIN, COMMUNICATION, LIVE),
/// et une 5e section ACCOUNTING en lecture seule si le module compta est
/// actif. Rename + reorder des sections possibles dès v1.
model ClubProject {
  id                 String        @id @default(uuid())
  clubId             String
  slug               String
  title              String
  summary            String?
  description        String?
  status             ProjectStatus @default(PLANNED)
  startsAt           DateTime?
  endsAt             DateTime?
  posterAssetId      String?
  coverImageId       String?
  budgetPlannedCents Int?

  /// Quotas par contributeur par phase LIVE — configurables par projet.
  maxPhotosPerContributorPerPhase Int     @default(10)
  maxVideosPerContributorPerPhase Int     @default(3)
  maxTextsPerContributorPerPhase  Int     @default(20)
  /// Toggle admin : afficher la liste des contributeurs en bas d'un
  /// compte-rendu publié (respect des contributeurs anonymes).
  showContributorCredits          Boolean @default(true)

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  club                  Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  posterAsset           MediaAsset?            @relation("ProjectPoster", fields: [posterAssetId], references: [id], onDelete: SetNull)
  coverImage            MediaAsset?            @relation("ProjectCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  sections              ProjectSection[]
  livePhases            ProjectLivePhase[]
  contributors          ProjectContributor[]
  liveItems             ProjectLiveItem[]
  reports               ProjectReport[]
  distributions         ProjectDistribution[]
  events                ClubEvent[]
  accountingEntries     AccountingEntry[]
  accountingAllocations AccountingAllocation[]
  grantApplications     GrantApplication[]
  sponsorshipDeals      SponsorshipDeal[]
  messageCampaigns      MessageCampaign[]
  agentConversations    AgentConversation[]

  @@unique([clubId, slug])
  @@index([clubId, status])
}

/// Section structurée d'un projet (wiki rich-text + documents joints via
/// MediaAsset.ownerKind='PROJECT_SECTION'). V1 : 4 kinds built-in + ACCOUNTING
/// lecture seule conditionnelle. Renommable, réordonnable.
model ProjectSection {
  id        String             @id @default(uuid())
  projectId String
  kind      ProjectSectionKind
  label     String
  sortOrder Int                @default(0)
  /// Wiki Tiptap JSON — contenu longue forme édité depuis l'admin.
  bodyJson  Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  project ClubProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}

/// Phase LIVE d'un projet — un projet peut avoir N phases (ex. stage 3 jours).
/// Chaque phase a son cycle `UPCOMING → LIVE → CLOSED` et ses propres quotas
/// contributeurs (les quotas sont comptés sur `phaseId` + `contributorId`).
model ProjectLivePhase {
  id        String                @id @default(uuid())
  projectId String
  label     String
  startsAt  DateTime
  endsAt    DateTime
  state     ProjectLivePhaseState @default(UPCOMING)
  openedAt  DateTime?
  closedAt  DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  project   ClubProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  liveItems ProjectLiveItem[]

  @@index([projectId, startsAt])
}

/// Contributeur d'un projet — polymorphe Member OU Contact (exactement un).
/// Portée par projet, rôle unique `CONTRIBUTOR` en v1, révocation manuelle
/// via `revokedAt` + raison, désactivation auto via hook Member.status.
model ProjectContributor {
  id            String                 @id @default(uuid())
  projectId     String
  memberId      String?
  contactId     String?
  role          ProjectContributorRole @default(CONTRIBUTOR)
  addedByUserId String
  addedAt       DateTime               @default(now())
  revokedAt     DateTime?
  revokedReason String?

  project   ClubProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member    Member?           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contact   Contact?          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  liveItems ProjectLiveItem[]

  @@index([projectId, revokedAt])
  @@index([memberId])
  @@index([contactId])
}

/// Item uploadé pendant la phase LIVE (photo ou vidéo). Pipeline :
///   PENDING (IA) → APPROVED/REJECTED/ERROR (aiDecision)
///   PENDING (humain) → APPROVED/REJECTED (humanDecision, override possible)
///   publishedTo : NONE par défaut, VITRINE_NEWS / VITRINE_BLOG /
///     MEMBER_ANNOUNCEMENT selon ce que l'admin publie.
model ProjectLiveItem {
  id                  String              @id @default(uuid())
  projectId           String
  phaseId             String?
  contributorId       String
  kind                ProjectLiveItemKind
  /// Nullable pour permettre les items de kind=TEXT (le textContent est
  /// alors renseigné à la place). Requis pour PHOTO et VIDEO — validation
  /// applicative dans `project-live-item.service.ts::submit()`.
  mediaAssetId        String?
  /// Contenu texte brut (max 4000 chars), pour kind=TEXT uniquement.
  /// Stocké tel quel, la modération IA texte peut le parcourir ensuite.
  textContent         String?
  submittedAt         DateTime            @default(now())
  /// False si l'upload a eu lieu après ProjectLivePhase.state=CLOSED.
  /// L'UI affiche alors un badge « ajout tardif ».
  submittedDuringLive Boolean             @default(true)

  aiDecision  ProjectLiveItemAiDecision @default(PENDING)
  aiReason    String?
  aiScore     Float?
  aiCheckedAt DateTime?

  humanDecision  ProjectLiveItemHumanDecision @default(PENDING)
  humanDecidedBy String?
  humanDecidedAt DateTime?

  publishedTo    ProjectLiveItemPublication @default(NONE)
  publishedRefId String?

  project     ClubProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       ProjectLivePhase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  contributor ProjectContributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  mediaAsset  MediaAsset?        @relation("ProjectLiveItemMedia", fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([projectId, submittedAt])
  @@index([projectId, aiDecision, humanDecision])
  @@index([contributorId, phaseId, kind])
}

/// Compte-rendu IA d'un projet. 3 templates (COMPETITIF / FESTIF / BILAN),
/// draft édité en Tiptap par l'admin puis publié comme VitrineArticle.
/// Stocke les contributeurs crédités pour l'attribution en bas d'article.
model ProjectReport {
  id                             String                     @id @default(uuid())
  projectId                      String
  template                       ProjectReportTemplate
  status                         ProjectReportStatus        @default(DRAFT)
  title                          String
  /// Prompt libre saisi par l'admin. Renseigné uniquement pour
  /// template=CUSTOM, null pour les 3 presets prédéfinis. Max 2000 chars.
  customPrompt                   String?
  bodyJson                       Json
  /// IDs des ProjectLiveItem effectivement utilisés par le générateur IA.
  sourceLiveItemIds              String[]                   @default([])
  /// IDs Member cités / crédités (union Member + Contact via deux colonnes
  /// parallèles — pattern FamilyMember).
  sourceContributorMemberIds     String[]                   @default([])
  sourceContributorContactIds    String[]                   @default([])
  publishedTo                    ProjectLiveItemPublication @default(NONE)
  publishedRefId                 String?
  generatedByAgentConversationId String?
  createdByUserId                String
  createdAt                      DateTime                   @default(now())
  publishedAt                    DateTime?
  updatedAt                      DateTime                   @updatedAt

  project ClubProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

/// Liste de diffusion club-level (réutilisable entre projets). Ex. « Mairie »,
/// « Partenaires », « Presse locale ». V2 — anticipé en v1 pour le schéma.
model DistributionList {
  id          String   @id @default(uuid())
  clubId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club          Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  contacts      DistributionContact[]
  distributions ProjectDistribution[]

  @@unique([clubId, name])
}

/// Contact d'une liste de diffusion — RGPD : consentement daté + source
/// obligatoires, unsubscribe trace via `consentRevokedAt`.
model DistributionContact {
  id               String    @id @default(uuid())
  listId           String
  firstName        String?
  lastName         String?
  organization     String?
  email            String
  phone            String?
  consentGivenAt   DateTime
  consentSource    String
  consentRevokedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  list  DistributionList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  sends DistributionSend[]

  @@unique([listId, email])
  @@index([email])
}

/// Envoi d'un mail projet → liste de diffusion (v2). Draft IA éditable puis
/// envoi via ClubSendingDomain + SPF/DKIM. Un `DistributionSend` par destinataire
/// avec token unsubscribe unique.
model ProjectDistribution {
  id                    String    @id @default(uuid())
  projectId             String
  listId                String
  subject               String
  bodyHtml              String
  bodyText              String?
  attachedMediaAssetIds String[]  @default([])
  aiDraftedAt           DateTime?
  createdByUserId       String
  createdAt             DateTime  @default(now())
  sentAt                DateTime?

  project ClubProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  list    DistributionList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  sends   DistributionSend[]

  @@index([projectId])
  @@index([listId])
}

/// Log immuable d'envoi pour audit RGPD — un send par (distribution, contact).
/// Seule la colonne `openedAt` est updatable (pixel tracking optionnel).
model DistributionSend {
  id               String                 @id @default(uuid())
  distributionId   String
  contactId        String
  /// Copie figée de l'email au moment de l'envoi (audit RGPD, évite de
  /// perdre la trace si le contact est modifié/supprimé après).
  email            String
  status           DistributionMailStatus @default(DRAFT)
  /// Token unique pour le lien unsubscribe dans le mail.
  unsubscribeToken String                 @unique
  sentAt           DateTime?
  deliveredAt      DateTime?
  openedAt         DateTime?
  errorMessage     String?

  distribution ProjectDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  contact      DistributionContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([distributionId, status])
}

// ============================================================================
// Module COMPTABILITÉ ANALYTIQUE IA (v1 — cf. plan glowing-bubbling-llama.md)
// ----------------------------------------------------------------------------
// Partie double pragmatique + OCR IA + analytique (projet, cohorte, gender,
// discipline, groupes dynamiques snapshot). Subventions workflow complet,
// sponsoring cash + nature (comptes 870/871). Verrouillage mensuel +
// clôture annuelle. Audit immuable. Budget IA mensuel.
// ============================================================================

/// Mode TVA du club. Impacte la saisie : NONE cache les champs HT/TVA,
/// MIXED/FULL les expose et applique les calculs PCG standards.
enum VatMode {
  NONE
  MIXED
  FULL
}

/// Nature comptable d'un compte du plan curated. Dicte la dérivation
/// automatique débit/crédit et le positionnement dans le bilan /
/// compte de résultat.
enum AccountingAccountKind {
  INCOME
  EXPENSE
  ASSET
  LIABILITY
  /// Comptes 870/871 "contributions volontaires en nature" — neutres au
  /// résultat mais tracés séparément pour bilan moral.
  NEUTRAL_IN_KIND
}

/// Type de document joint à une écriture comptable.
enum AccountingDocumentKind {
  RECEIPT
  INVOICE
  QUOTE
  CONTRACT
  REPORT
  OTHER
}

/// Actions tracées dans le journal d'audit immuable.
enum AccountingAuditAction {
  CREATE
  UPDATE
  LOCK
  UNLOCK
  CANCEL
  CONTRAPASS
  EXPORT
  FISCAL_YEAR_CLOSE
}

/// Plan comptable curated par club (~30 comptes PCG associatif seedés à
/// l'activation du module, extensibles par le trésorier).
model AccountingAccount {
  id        String                @id @default(uuid())
  clubId    String
  /// Code PCG (ex "606400" pour "Achats non stockés fournitures"). Unique
  /// par club.
  code      String
  /// Libellé lisible (snapshot copié sur chaque ligne d'écriture à la
  /// création pour persistance même si le compte est renommé).
  label     String
  kind      AccountingAccountKind
  /// True si le compte fait partie du sous-ensemble seedé par défaut.
  /// Permet de distinguer les comptes standards des ajouts custom.
  isDefault Boolean               @default(false)
  isActive  Boolean               @default(true)
  sortOrder Int                   @default(0)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  club              Club                       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  mappings          AccountingAccountMapping[]
  financialAccounts ClubFinancialAccount[]

  @@unique([clubId, code])
  @@index([clubId, kind])
  @@index([clubId, isActive])
}

/// Mapping d'une source (produit d'adhésion, frais one-time, vente shop,
/// subvention, sponsoring) vers un compte du plan comptable. Utilisé par
/// l'analytique auto pour savoir sur quel compte PCG imputer une
/// encaissement automatique.
model AccountingAccountMapping {
  id          String   @id @default(uuid())
  clubId      String
  /// Type de source. Convention string libre :
  /// MEMBERSHIP_PRODUCT | MEMBERSHIP_ONE_TIME_FEE | SHOP_PRODUCT |
  /// SUBSIDY | SPONSORSHIP_CASH | SPONSORSHIP_IN_KIND | STRIPE_FEE |
  /// BANK_ACCOUNT.
  sourceType  String
  /// ID de la source spécifique. Null = mapping par défaut pour ce
  /// `sourceType` (fallback).
  sourceId    String?
  accountId   String
  /// Dénormalisé pour lookup rapide sans jointure.
  accountCode String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account AccountingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([clubId, sourceType, sourceId])
  @@index([clubId, sourceType])
}

/// Cohortes analytiques (tranches d'âge) configurables par club. 5 defaults
/// seedés : BABY 0-5, ENFANT 6-11, ADO 12-17, ADULTE 18-59, SENIOR 60+.
/// Custom codes préfixés "CUSTOM_".
model AccountingCohort {
  id        String   @id @default(uuid())
  clubId    String
  code      String
  label     String
  /// Inclusif. Null = pas de borne basse.
  minAge    Int?
  /// Inclusif. Null = pas de borne haute.
  maxAge    Int?
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club        Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  allocations AccountingAllocation[]

  @@unique([clubId, code])
  @@index([clubId])
}

/// Ligne comptable d'une écriture (partie double). Chaque entry a au moins
/// 2 lignes dont la somme des débits = somme des crédits.
model AccountingEntryLine {
  id               String             @id @default(uuid())
  entryId          String
  /// Dénormalisé multi-tenant safety.
  clubId           String
  /// Code PCG ex "606400".
  accountCode      String
  /// Snapshot du label compte à la création (persiste même si renommage).
  accountLabel     String
  /// Libellé libre de la ligne (optionnel).
  label            String?
  /// AUTO = dérivé à la création depuis (accountKind, entryKind).
  /// DEBIT/CREDIT = forcé (contre-passations, ajustements).
  side             AccountingLineSide @default(AUTO)
  /// Matérialisé pour FEC-readiness : exactement une des deux colonnes > 0.
  debitCents       Int                @default(0)
  creditCents      Int                @default(0)
  vatRate          Decimal?           @db.Decimal(5, 2)
  vatAmountCents   Int?
  sortOrder        Int                @default(0)
  /// Marqueur de rapprochement bancaire (anticipation v2+). Non utilisé
  /// en v1 mais schéma posé pour éviter une migration future.
  bankReconciledAt DateTime?
  createdAt        DateTime           @default(now())

  // --- Validation par ligne (flow NEEDS_REVIEW → POSTED granulaire) ---
  /// Timestamp de validation humaine de la ligne. Null = en attente de
  /// revue. Quand toutes les lignes "article" (hors contrepartie banque)
  /// sont validées, l'entry parente passe automatiquement en POSTED.
  validatedAt       DateTime?
  validatedByUserId String?

  // --- Traçabilité suggestion IA (pour affichage dans la review UI) ---
  /// Compte PCG proposé par l'IA. Gardé même si l'user change le compte
  /// final (pour audit et comparaison).
  iaSuggestedAccountCode  String?
  /// Phrase d'explication IA du choix (max 300 chars).
  iaReasoning             String?
  /// Score de confiance IA sur le compte (0-100).
  iaConfidencePct         Int?
  /// Si la ligne résulte d'une consolidation, contient les labels des
  /// articles d'origine fusionnés. Vide = ligne non consolidée. Permet
  /// d'afficher en tooltip "Cette ligne regroupe : Entrée, Plat, Dessert".
  mergedFromArticleLabels String[] @default([])

  entry       AccountingEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)
  allocations AccountingAllocation[]

  @@index([entryId])
  @@index([clubId, accountCode])
}

/// Ventilation analytique d'une ligne comptable. N allocations par ligne,
/// sommant exactement le montant de la ligne. Portent les dimensions :
/// projet, cohorte, gender, discipline, membre, groupes dynamiques
/// (snapshot + table normalisée), tags libres.
model AccountingAllocation {
  id                         String   @id @default(uuid())
  lineId                     String
  /// Dénormalisé multi-tenant safety.
  clubId                     String
  amountCents                Int
  projectId                  String?
  /// Code cohorte (FK composite vers AccountingCohort).
  cohortCode                 String?
  gender                     Gender?
  /// Code discipline snapshot (ex "karate", "judo"). Libre, minuscule.
  disciplineCode             String?
  memberId                   String?
  /// Flag RGPD : si true, memberId a été anonymisé (droit à l'oubli) et
  /// les dynamicGroupLabelsSnapshot/disciplineCode restent pour garder
  /// les totaux justes sans l'identité.
  memberIdAnonymized         Boolean  @default(false)
  // NOTE : field `gender Gender?` (pas AccountingAllocationGender — on
  // réutilise l'enum Member pour cohérence). Déclaré juste avant memberId.
  /// Snapshot IDs des groupes dynamiques au moment du paiement. Array
  /// pour affichage rapide. Les requêtes analytiques passent par la
  /// table normalisée AccountingAllocationGroupTag.
  dynamicGroupIdsSnapshot    String[] @default([])
  /// Snapshot des labels groupes (persiste même si le groupe est
  /// renommé ou supprimé).
  dynamicGroupLabelsSnapshot String[] @default([])
  /// Tags libres ajoutés manuellement par le saisisseur.
  freeformTags               String[] @default([])
  createdAt                  DateTime @default(now())

  line      AccountingEntryLine            @relation(fields: [lineId], references: [id], onDelete: Cascade)
  project   ClubProject?                   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  member    Member?                        @relation(fields: [memberId], references: [id], onDelete: SetNull)
  cohort    AccountingCohort?              @relation(fields: [clubId, cohortCode], references: [clubId, code])
  groupTags AccountingAllocationGroupTag[]

  @@index([clubId, projectId])
  @@index([clubId, cohortCode])
  @@index([clubId, disciplineCode])
  @@index([memberId])
  @@index([lineId])
}

/// Table normalisée pour les queries analytiques sur les groupes
/// dynamiques. En complément du snapshot array sur l'allocation.
model AccountingAllocationGroupTag {
  id           String   @id @default(uuid())
  allocationId String
  clubId       String
  groupId      String
  /// Snapshot label (persiste si le groupe est supprimé ultérieurement).
  groupLabel   String
  createdAt    DateTime @default(now())

  allocation AccountingAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@unique([allocationId, groupId])
  @@index([clubId, groupId])
}

/// Verrou mensuel de la compta. Une fois posé par le trésorier, les
/// entries du mois deviennent immutables (sauf création de contre-passation
/// datée d'un mois ouvert).
model AccountingPeriodLock {
  id             String   @id @default(uuid())
  clubId         String
  /// Format "YYYY-MM".
  month          String
  lockedAt       DateTime @default(now())
  lockedByUserId String

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, month])
  @@index([clubId])
}

/// Clôture annuelle. Verrouille tous les mois de l'année + snapshot des
/// totaux pour audit. Une fois fermée, aucune manipulation possible.
model AccountingFiscalYearClose {
  id             String   @id @default(uuid())
  clubId         String
  year           Int
  closedAt       DateTime @default(now())
  closedByUserId String
  /// Snapshot JSON des totaux à la clôture : { revenues, expenses,
  /// result, byAccount: {...}, byProject: {...} }.
  snapshotJson   Json?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, year])
  @@index([clubId])
}

/// Résultat brut d'une extraction IA (OCR reçu/facture). Persistée pour
/// audit et reprise (l'user peut corriger plusieurs fois avant validation
/// finale, la base reste stable).
model AccountingExtraction {
  id                   String    @id @default(uuid())
  clubId               String
  mediaAssetId         String
  /// Output brut JSON du modèle vision (pour rejouer si besoin).
  rawJson              Json
  /// Score de confiance par champ extrait : { total: 0.9, date: 0.7, ... }.
  confidencePerField   Json
  extractedTotalCents  Int?
  extractedVatCents    Int?
  extractedDate        DateTime?
  extractedVendor      String?
  /// Proposition de compte PCG par l'IA (à valider par l'humain).
  extractedAccountCode String?
  model                String
  inputTokens          Int       @default(0)
  outputTokens         Int       @default(0)
  costCents            Int       @default(0)
  /// Nombre de pages traitées (PDF multi-pages).
  pageCount            Int       @default(1)
  /// Si non null, l'extraction a échoué (OpenRouter timeout, JSON invalide,
  /// budget IA épuisé). L'user saisit manuellement.
  error                String?
  createdAt            DateTime  @default(now())

  mediaAsset MediaAsset        @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  entries    AccountingEntry[]

  @@index([clubId, createdAt])
}

/// Log d'audit immuable (append-only). Toute création / modification /
/// annulation / clôture génère une entrée ici.
model AccountingAuditLog {
  id        String                @id @default(uuid())
  clubId    String
  /// Null pour actions globales (ex: clôture d'exercice).
  entryId   String?
  userId    String
  action    AccountingAuditAction
  /// Diff before/after des champs modifiés (pour UPDATE).
  diffJson  Json?
  /// Contexte additionnel (motif de contre-passation, raison d'annulation,
  /// filtres d'export CSV, etc.).
  metadata  Json?
  createdAt DateTime              @default(now())

  club  Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  entry AccountingEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([clubId, createdAt])
  @@index([entryId])
}

/// Jointure entry ↔ mediaAsset pour attacher N documents à une écriture.
/// Unique par paire pour éviter les doublons.
model AccountingDocument {
  id           String                 @id @default(uuid())
  clubId       String
  entryId      String
  mediaAssetId String
  kind         AccountingDocumentKind @default(RECEIPT)
  createdAt    DateTime               @default(now())

  entry      AccountingEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset      @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([entryId, mediaAssetId])
  @@index([clubId])
}

/// Agrégation mensuelle de l'usage IA par club. Incrémentée à chaque
/// appel via AiBudgetService. Remplace les scalaires sur Club pour offrir
/// un historique mensuel exploitable (trend graphs, budgets par mois).
model AiMonthlyUsage {
  id               String   @id @default(uuid())
  clubId           String
  /// Format "YYYY-MM".
  yearMonth        String
  totalCostCents   Int      @default(0)
  inputTokens      BigInt   @default(0)
  outputTokens     BigInt   @default(0)
  imagesGenerated  Int      @default(0)
  /// Breakdown par feature : { RECEIPT_OCR: 1200, ARTICLE_GENERATION: 300 }.
  featureBreakdown Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, yearMonth])
  @@index([clubId])
}
