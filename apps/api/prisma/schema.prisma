  @@index([clubId])
}

model CourseSlot {
  id              String    @id @default(uuid())
  clubId          String
  venueId         String
  coachMemberId   String
  title           String
  startsAt        DateTime
  endsAt          DateTime
  dynamicGroupId  String?
  bookingEnabled  Boolean   @default(false)
  bookingCapacity Int?
  bookingOpensAt  DateTime?
  bookingClosesAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  club         Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  venue        Venue               @relation(fields: [venueId], references: [id], onDelete: Restrict)
  coachMember  Member              @relation("CourseSlotCoach", fields: [coachMemberId], references: [id], onDelete: Restrict)
  dynamicGroup DynamicGroup?       @relation(fields: [dynamicGroupId], references: [id], onDelete: SetNull)
  bookings     CourseSlotBooking[]

