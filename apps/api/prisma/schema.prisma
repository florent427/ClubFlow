generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Club {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// URL (ou chemin statique relatif /uploads/...) du logo imprimé sur les factures.
  logoUrl       String?
  /// SIRET du club (facultatif, affiché en pied de facture PDF).
  siret         String?
  /// Adresse complète postale, multi-ligne séparées par `\n`.
  address       String?
  /// Mentions légales en pied de facture (TVA non applicable, association loi 1901…).
  legalMentions String?
  /// Téléphone de contact du club affiché sur l'en-tête de facture.
  contactPhone  String?
  /// E-mail de contact du club affiché sur l'en-tête de facture.
  contactEmail  String?

  memberships     ClubMembership[]
  modules         ClubModule[]
  gradeLevels     GradeLevel[]
  roleDefinitions ClubRoleDefinition[]
  members         Member[]
  dynamicGroups   DynamicGroup[]
  families        Family[]
  householdGroups HouseholdGroup[]
  venues          Venue[]
  courseSlots     CourseSlot[]

  pricingRules                    ClubPricingRule[]
  invoices                        Invoice[]
  payments                        Payment[]
  messageCampaigns                MessageCampaign[]
  accountingEntries               AccountingEntry[]
  grantApplications               GrantApplication[]
  sponsorshipDeals                SponsorshipDeal[]
  memberFieldCatalogSettings      ClubMemberFieldCatalogSetting[]
  memberCustomFieldDefinitions    MemberCustomFieldDefinition[]
  clubSeasons                     ClubSeason[]
  membershipProducts              MembershipProduct[]
  membershipOneTimeFees           MembershipOneTimeFee[]
  membershipPricingRules          MembershipPricingRule[]
  sendingDomains                  ClubSendingDomain[]
  emailSuppressions               EmailSuppression[]
  contacts                        Contact[]
  chatRooms                       ChatRoom[]
  membershipCarts                 MembershipCart[]
  /// À partir du n-ième bulletin d’adhésion (OPEN/PAID) pour le foyer sur la saison — null = désactivé
  membershipFamilyDiscountFromNth Int?
  membershipFamilyAdjustmentType  PricingAdjustmentType           @default(NONE)
  membershipFamilyAdjustmentValue Int                             @default(0)

  /// Nombre de mois de **plein tarif** au début de la saison avant que
  /// le prorata ne commence à s'appliquer. Les inscriptions arrivant
  /// pendant cette fenêtre paient le tarif annuel complet (pas de
  /// remise prorata). À partir du mois N+1, le prorata classique
  /// s'applique. Default = 3 (les 3 premiers mois plein tarif).
  /// 0 = prorata dès le 1er mois (ancien comportement).
  membershipFullPriceFirstMonths  Int                             @default(3)

  /// Domaine personnalisé pour le site vitrine public (ex. www.mondojo.fr).
  /// CNAME à poser vers le serveur Next.js ; HTTPS géré par le reverse-proxy.
  customDomain     String? @unique
  /// Flag « site vitrine publié ». Quand false, le site renvoie 404 publique
  /// (seuls les aperçus admin restent accessibles).
  vitrinePublished Boolean @default(false)

  /// Tagline affichée sous le nom du club dans la nav et le footer.
  /// Ex. "空手道 · Sud Réunion" pour un dojo.
  vitrineKanjiTagline String?

  /// JSON sérialisé du contenu de footer (colonnes, contact, social, bottom).
  /// Si null, fallback hard-codé côté vitrine pour ne jamais casser le rendu.
  vitrineFooterJson Json?

  /// Palette couleurs personnalisée du site vitrine (JSON).
  /// Schéma : { ink, ink2, paper, accent, goldBright, vermillion, line, muted }
  /// Si null → palette SKSR par défaut côté vitrine.
  vitrinePaletteJson Json?

  /// Typographies personnalisées du site vitrine (JSON).
  /// Schéma : { serif, sans, jp }  — chaque clé est le nom d'une police Google Fonts.
  /// Si null → fonts SKSR par défaut (Cormorant/Inter/Shippori Mincho).
  vitrineFontsJson Json?

  vitrinePages         VitrinePage[]
  vitrineArticles      VitrineArticle[]
  vitrineAnnouncements VitrineAnnouncement[]
  vitrineGalleryPhotos VitrineGalleryPhoto[]
  vitrineCategories    VitrineCategory[]
  mediaAssets          MediaAsset[]
  clubProjects         ClubProject[]
  distributionLists    DistributionList[]

  /// Clé API OpenRouter (chiffrée AES-256-GCM, base64).
  /// null = fonctionnalités IA désactivées pour ce club.
  aiOpenrouterApiKeyEnc String?

  /// Modèle texte (ex. anthropic/claude-sonnet-4-5).
  aiTextModel String?

  /// Modèle texte de fallback (utilisé si le primaire échoue 3× sur un tool
  /// call ou renvoie une erreur 5xx/timeout). Null = pas de fallback.
  aiTextFallbackModel String?

  /// Modèle image (ex. google/gemini-2.5-flash-image-preview).
  aiImageModel String?

  /// Compteurs cumulés de consommation IA.
  aiTokensInputUsed  BigInt @default(0)
  aiTokensOutputUsed BigInt @default(0)
  aiImagesGenerated  Int    @default(0)

  /// Budget IA mensuel maximum en centimes d'euros. Null = illimité (l'usage
  /// est tracé mais non bloqué). Soft cap déclenché à 80 %, hard cap à 100 %
  /// (OCR tombe en saisie manuelle).
  aiMonthlyBudgetCents         Int?
  /// Override temporaire du cap — permet au trésorier de débloquer l'IA en
  /// fin de mois pour une saisie critique. Null = pas d'override actif.
  aiMonthlyBudgetOverrideCents Int?

  aiUsageLogs     AiUsageLog[]
  aiMonthlyUsages AiMonthlyUsage[]

  /// Feature flag : agent conversationnel activé pour ce club.
  /// Même si true, peut être désactivé globalement via env AGENT_GLOBAL_KILLED=true.
  agentEnabled Boolean @default(true)

  agentConversations  AgentConversation[]
  agentPendingActions AgentPendingAction[]

  /// Mode TVA du club pour la comptabilité. NONE = assoc non assujettie (cas
  /// le plus courant), MIXED = assujettissement partiel (buvette, évén.),
  /// FULL = totalement assujettie.
  vatMode VatMode @default(NONE)

  accountingAccounts         AccountingAccount[]
  accountingCohorts          AccountingCohort[]
  accountingPeriodLocks      AccountingPeriodLock[]
  accountingFiscalYearCloses AccountingFiscalYearClose[]
  accountingAuditLogs        AccountingAuditLog[]
  financialAccounts          ClubFinancialAccount[]
  paymentRoutes              ClubPaymentRoute[]
}

enum AiUsageFeature {
  ARTICLE_GENERATION
  IMAGE_GENERATION
  AGENT_CHAT
  /// Modération IA des items live uploadés par les contributeurs projet
  /// (vision pertinence + qualité).
  PROJECT_MODERATION
  /// Génération de comptes-rendus projet (3 presets : COMPETITIF, FESTIF,
  /// BILAN) via le module Projets.
  PROJECT_REPORT
  /// OCR de reçus / factures pour la comptabilité analytique via OpenRouter vision.
  RECEIPT_OCR
  OTHER
}

enum AgentMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum AgentToolCallStatus {
  PENDING_CONFIRMATION
  EXECUTED
  REFUSED
  FAILED
  BLOCKED_BY_LIMITS
  BLOCKED_BY_SCOPE
}

enum AgentRiskLevel {
  SAFE
  GUARDED
  DESTRUCTIVE
  FORBIDDEN
}

/// Conversation ouverte par un utilisateur avec l'agent.
model AgentConversation {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  /// Scope projet : si non null, la conversation est cantonnée au projet X,
  /// seuls les outils `scope = 'PROJECT'` seront exposés à l'agent + le
  /// system prompt est enrichi du contexte projet (titre, contributeurs,
  /// items live récents). Null = agent club classique (portée historique).
  projectId String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archived  Boolean  @default(false)

  club     Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  project  ClubProject?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([clubId, userId, updatedAt])
  @@index([projectId])
}

/// Message individuel dans une conversation (user, assistant, tool result).
model AgentMessage {
  id              String           @id @default(uuid())
  conversationId  String
  role            AgentMessageRole
  /// Texte pour role=USER|ASSISTANT|SYSTEM. Pour role=TOOL, JSON résultat.
  content         String
  /// Résumé token usage quand role=ASSISTANT.
  inputTokens     Int?
  outputTokens    Int?
  model           String?
  /// Pièces jointes du message (images, PDF, docs). JSON array :
  /// [{ mediaAssetId, kind: 'IMAGE'|'DOCUMENT', mimeType, fileName, publicUrl, extractedText? }]
  /// Seuls les USER messages en utilisent.
  attachmentsJson Json?
  createdAt       DateTime         @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls    AgentToolCall[]

  @@index([conversationId, createdAt])
}

/// Un appel de tool requested par le LLM, avec son résultat ou son état.
model AgentToolCall {
  id              String              @id @default(uuid())
  messageId       String
  toolName        String
  argsJson        Json
  riskLevel       AgentRiskLevel
  status          AgentToolCallStatus
  /// JSON du résultat d'exécution (seulement si status=EXECUTED).
  resultJson      Json?
  errorMessage    String?
  /// Si pending confirmation, lien vers le PendingAction.
  pendingActionId String?
  createdAt       DateTime            @default(now())
  executedAt      DateTime?

  message AgentMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
}

/// Action en attente de confirmation humaine (destructive/guarded).
/// Signée anti-replay, expire en 5 min.
model AgentPendingAction {
  id             String              @id @default(uuid())
  clubId         String
  userId         String
  conversationId String
  toolName       String
  argsJson       Json
  riskLevel      AgentRiskLevel
  /// Preview en français de l'action (affichée à l'utilisateur).
  previewText    String
  /// Signature HMAC pour anti-replay.
  signature      String
  status         AgentToolCallStatus @default(PENDING_CONFIRMATION)
  createdAt      DateTime            @default(now())
  expiresAt      DateTime
  resolvedAt     DateTime?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, userId, status])
  @@index([expiresAt])
}

/// Historique des appels IA (un par mutation).
model AiUsageLog {
  id              String         @id @default(uuid())
  clubId          String
  feature         AiUsageFeature
  model           String
  inputTokens     Int            @default(0)
  outputTokens    Int            @default(0)
  imagesGenerated Int            @default(0)
  /// Coût en cents (si disponible dans la réponse OpenRouter).
  costCents       Int?
  userId          String?
  createdAt       DateTime       @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
}

enum MembershipRole {
  CLUB_ADMIN
  BOARD
  COACH
  TREASURER
  SECRETARY
  STAFF
  /// Responsable communication — accès délégué à l'éditorial du site
  /// vitrine (pages, articles, annonces, galerie, médias) sans les droits
  /// financiers/administratifs complets.
  COMM_MANAGER
  /// Chef de projet — peut créer, administrer et archiver des ClubProject
  /// sans avoir tous les droits CLUB_ADMIN. Ne donne PAS accès aux autres
  /// modules (compta, membres hors projet, paramètres club).
  PROJECT_MANAGER
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?
  emailVerifiedAt DateTime?
  displayName     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  /// PIN à 4 chiffres (hashé bcrypt) qui protège l'accès aux pages
  /// /factures + /famille du portail (espace payeur). Optionnel ; si
  /// null, l'accès est libre dès qu'on est PAYER.
  payerSpacePinHash String?

  memberships             ClubMembership[]
  tokens                  RefreshToken[]
  members                 Member[]
  contacts                Contact[]
  userIdentities          UserIdentity[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

enum OAuthProvider {
  GOOGLE
  FACEBOOK
  LINKEDIN
}

/// Prospect / contact portail — distinct du membre adhérent (`Member`)
model Contact {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  firstName String
  lastName  String
  phone     String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club                   Club                        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user                   User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Liens `FamilyMember` où ce contact est désigné payeur (`linkRole = PAYER`).
  familyMemberPayerLinks FamilyMember[]              @relation("FamilyMemberPayerContact")
  paymentsAsPaidBy       Payment[]                   @relation("PaymentPaidByContact")
  membershipCartsAsPayer MembershipCart[]            @relation("CartPayerContact")
  pendingMembershipItems MembershipCartPendingItem[] @relation("PendingItemContact")
  projectContributions   ProjectContributor[]
  sponsorshipDeals       SponsorshipDeal[]

  @@unique([userId, clubId])
}

model UserIdentity {
  id              String        @id @default(uuid())
  userId          String
  provider        OAuthProvider
  providerSubject String
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ClubMembership {
  id        String         @id @default(uuid())
  userId    String
  clubId    String
  role      MembershipRole @default(STAFF)
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

model ModuleDefinition {
  code        String       @id
  label       String
  isRequired  Boolean      @default(false)
  description String?
  clubModules ClubModule[]
}

model ClubModule {
  id         String    @id @default(uuid())
  clubId     String
  moduleCode String
  enabled    Boolean   @default(false)
  enabledAt  DateTime?
  disabledAt DateTime?

  club   Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  module ModuleDefinition @relation(fields: [moduleCode], references: [code], onDelete: Restrict)

  @@unique([clubId, moduleCode])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Module Membres (référentiel adhérents + grades + groupes dynamiques) ---

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum MemberClubRole {
  STUDENT
  COACH
  BOARD
}

/// Genre déclaratif du membre, utilisé pour l'analytique comptable (ventilation
/// cotisations par sexe) et les statistiques licenciés. UNSPECIFIED = non
/// renseigné / préfère ne pas dire.
enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

enum MemberCivility {
  MR
  MME
}

/// Champs « catalogue » (colonnes Member) configurables sur la fiche admin
enum MemberCatalogFieldKey {
  PHONE
  ADDRESS_LINE
  POSTAL_CODE
  CITY
  BIRTH_DATE
  PHOTO_URL
  MEDICAL_CERT_EXPIRES_AT
  GRADE_LEVEL
}

enum MemberCustomFieldType {
  TEXT
  TEXT_LONG
  NUMBER
  DATE
  BOOLEAN
  SELECT
}

model ClubMemberFieldCatalogSetting {
  id         String                @id @default(uuid())
  clubId     String
  fieldKey   MemberCatalogFieldKey
  showOnForm Boolean               @default(true)
  required   Boolean               @default(false)
  sortOrder  Int                   @default(0)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, fieldKey])
  @@index([clubId])
}

model MemberCustomFieldDefinition {
  id              String                @id @default(uuid())
  clubId          String
  code            String
  label           String
  type            MemberCustomFieldType
  required        Boolean               @default(false)
  sortOrder       Int                   @default(0)
  visibleToMember Boolean               @default(false)
  optionsJson     String?
  archivedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  club   Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  values MemberCustomFieldValue[]

  @@unique([clubId, code])
  @@index([clubId])
}

model MemberCustomFieldValue {
  id           String   @id @default(uuid())
  memberId     String
  definitionId String
  valueText    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  member     Member                      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  definition MemberCustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([memberId, definitionId])
  @@index([memberId])
  @@index([definitionId])
}

model GradeLevel {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club                         Club                          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members                      Member[]
  dynamicGroupGradeLevels      DynamicGroupGradeLevel[]
  membershipProductGradeLevels MembershipProductGradeLevel[]

  @@index([clubId])
}

model Member {
  id                   String         @id @default(uuid())
  clubId               String
  userId               String?
  firstName            String
  lastName             String
  /// Pseudo messagerie ; unique par club ; [a-z0-9_]
  pseudo               String         @db.VarChar(64)
  civility             MemberCivility
  /// Genre déclaratif utilisé pour l'analytique comptable (ventilation
  /// cotisations M/F). UNSPECIFIED par défaut (backfill sûr).
  gender               Gender         @default(UNSPECIFIED)
  email                String
  phone                String?
  addressLine          String?
  postalCode           String?
  city                 String?
  birthDate            DateTime?
  photoUrl             String?
  medicalCertExpiresAt DateTime?
  status               MemberStatus   @default(ACTIVE)
  gradeLevelId         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  club                      Club                         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user                      User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  gradeLevel                GradeLevel?                  @relation(fields: [gradeLevelId], references: [id], onDelete: SetNull)
  roleAssignments           MemberRoleAssignment[]
  customRoleAssignments     MemberCustomRoleAssignment[]
  familyMembers             FamilyMember[]
  courseSlotsAsCoach        CourseSlot[]                 @relation("CourseSlotCoach")
  courseSlotBookings        CourseSlotBooking[]          @relation("CourseSlotBookingMember")
  messageCampaignRecipients MessageCampaignRecipient[]
  customFieldValues         MemberCustomFieldValue[]
  dynamicGroupAssignments   MemberDynamicGroup[]
  invoiceLines              InvoiceLine[]
  paymentsAsPaidBy          Payment[]                    @relation("PaymentPaidByMember")
  telegramChatId            String?                      @map("telegram_chat_id")
  telegramLinkedAt          DateTime?                    @map("telegram_linked_at")
  telegramLinkTokens        TelegramLinkToken[]
  chatRoomMemberships       ChatRoomMember[]
  chatMessagesSent          ChatMessage[]                @relation("ChatMessageSender")
  chatRoomsCreated          ChatRoom[]                   @relation("MemberChatRoomsCreated")
  chatMessageReactions      ChatMessageReaction[]

  /// Numéro de licence fédérale validé (saisi une fois via « J'ai déjà une licence »).
  licenseNumber             String?
  membershipCartItems       MembershipCartItem[]
  membershipCartsAsPayer    MembershipCart[]            @relation("CartPayerMember")
  /// Snapshot d'une inscription pending convertie en ce Member réel.
  convertedFromPendingItems MembershipCartPendingItem[] @relation("PendingItemConvertedMember")
  projectContributions      ProjectContributor[]
  accountingAllocations     AccountingAllocation[]

  @@unique([clubId, userId])
  @@unique([clubId, pseudo])
  @@index([clubId])
  @@index([clubId, status])
}

enum ChatRoomKind {
  DIRECT
  GROUP
  COMMUNITY
}

enum ChatRoomMemberRole {
  MEMBER
  ADMIN
}

/// Mode d'écriture d'un salon (groupe administré).
/// OPEN     = tous les membres du salon peuvent poster un message racine.
/// RESTRICTED = seuls les rôles autorisés (ChatRoomWritePermission) peuvent
///              poster un message racine. Les autres peuvent seulement
///              répondre en fil (thread) à un message existant.
/// READ_ONLY = personne ne peut poster ni répondre, sauf un admin via
///              "poster comme membre" (broadcast pur). Réactions toujours OK.
enum ChatRoomChannelMode {
  OPEN
  RESTRICTED
  READ_ONLY
}

/// Référentiel pour les permissions d'écriture d'un salon.
/// SYSTEM_ROLE = rôle système Membership (CLUB_ADMIN, BOARD, COACH, ...)
/// MEMBER_ROLE = rôle adhérent (STUDENT, COACH, BOARD)
/// CUSTOM_ROLE = ClubRoleDefinition (rôle libellé créé par le club)
/// CONTACT     = personne avec un lien Contact (parent payeur sans Member)
enum ChatRoomPermissionTarget {
  SYSTEM_ROLE
  MEMBER_ROLE
  CUSTOM_ROLE
  CONTACT
}

model ChatRoom {
  id                  String              @id @default(uuid())
  clubId              String
  kind                ChatRoomKind
  name                String?
  description         String?             @db.Text
  /// Image de couverture du salon (groupe administré).
  coverImageUrl       String?
  /// Mode d'écriture pour les groupes administrés.
  channelMode         ChatRoomChannelMode @default(OPEN)
  /// Si true, le salon apparaît comme canal de diffusion dans
  /// l'interface "Communication" admin (à côté de email/telegram/push).
  isBroadcastChannel  Boolean             @default(false)
  /// Salon archivé : reste lisible mais en lecture seule, masqué par défaut.
  archivedAt          DateTime?
  directPairKey       String?             @unique
  createdByMemberId   String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  club     Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator  Member?          @relation("MemberChatRoomsCreated", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  members  ChatRoomMember[]
  messages ChatMessage[]
  writePermissions ChatRoomWritePermission[]
  membershipScopes ChatRoomMembershipScope[]

  @@index([clubId, kind])
  @@index([clubId, isBroadcastChannel])
}

model ChatRoomMember {
  id       String             @id @default(uuid())
  roomId   String
  memberId String
  role     ChatRoomMemberRole @default(MEMBER)
  joinedAt DateTime           @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  member Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([roomId, memberId])
  @@index([memberId])
}

/// Permission d'écriture (poster un message racine) pour un salon RESTRICTED.
/// Vide => tous les membres du salon peuvent poster. Sinon, l'union des
/// rôles ciblés détermine qui peut écrire.
model ChatRoomWritePermission {
  id          String                   @id @default(uuid())
  roomId      String
  clubId      String
  targetKind  ChatRoomPermissionTarget
  /// Valeur dépendant de targetKind : enum stringifié pour SYSTEM_ROLE /
  /// MEMBER_ROLE, ID de ClubRoleDefinition pour CUSTOM_ROLE, null pour CONTACT.
  targetValue String?
  createdAt   DateTime                 @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, targetKind, targetValue])
  @@index([clubId, roomId])
}

/// Définit la portée d'un salon administré : qui est inscrit dedans.
/// Vide => le salon est manuel (création explicite des ChatRoomMember).
/// Sinon : l'union des scopes calcule la liste des Member, recomputée à la
/// volée par le service quand un membre est ajouté/retiré ou que les rôles
/// changent.
model ChatRoomMembershipScope {
  id              String                   @id @default(uuid())
  roomId          String
  clubId          String
  targetKind      ChatRoomPermissionTarget
  /// Valeur dépendant de targetKind (cf ChatRoomWritePermission).
  /// Pour DynamicGroup, on utilise un targetKind dédié dans une future itération.
  targetValue     String?
  /// ID de DynamicGroup si scope = groupe dynamique. Mutuellement exclusif
  /// avec targetKind/targetValue sur cette ligne.
  dynamicGroupId  String?
  createdAt       DateTime @default(now())

  room          ChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  dynamicGroup  DynamicGroup? @relation(fields: [dynamicGroupId], references: [id], onDelete: Cascade)

  @@index([clubId, roomId])
  @@index([dynamicGroupId])
}

model ChatMessage {
  id                  String    @id @default(uuid())
  roomId              String
  senderMemberId      String
  body                String    @db.Text
  /// Si non null, ce message est une réponse en fil au message désigné.
  /// Les réponses ne sont pas affichées dans le flux principal du salon
  /// (récupérées via thread expand uniquement).
  parentMessageId     String?
  /// Compteur dénormalisé du nombre de réponses au message racine
  /// (mis à jour quand une réponse est postée).
  replyCount          Int       @default(0)
  /// Date de la dernière réponse (pour ordonner / afficher "X réponses").
  lastReplyAt         DateTime?
  /// Si non null : un admin a posté ce message en se faisant passer pour
  /// le membre senderMemberId. Stocké pour audit.
  postedAsAdminUserId String?
  createdAt           DateTime  @default(now())
  editedAt            DateTime?
  deletedAt           DateTime?

  room      ChatRoom              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    Member                @relation("ChatMessageSender", fields: [senderMemberId], references: [id], onDelete: Cascade)
  parent    ChatMessage?          @relation("ChatMessageThread", fields: [parentMessageId], references: [id], onDelete: Cascade)
  replies   ChatMessage[]         @relation("ChatMessageThread")
  reactions ChatMessageReaction[]

  @@index([roomId, createdAt])
  @@index([parentMessageId, createdAt])
}

/// Réaction emoji sur un message (1 emoji par membre par message).
model ChatMessageReaction {
  id        String   @id @default(uuid())
  messageId String
  memberId  String
  clubId    String
  /// Emoji court (Unicode), ex: "👍", "❤️", "😂". Limité à 16 caractères.
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  member  Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([messageId, memberId, emoji])
  @@index([messageId])
  @@index([clubId, memberId])
}

/// Jeton ponctuel pour `t.me/Bot?start=TOKEN` — lie le chat Telegram au membre.
model TelegramLinkToken {
  id         String    @id @default(uuid())
  clubId     String
  memberId   String
  token      String    @unique @db.VarChar(64)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([token])
}

model MemberRoleAssignment {
  id        String         @id @default(uuid())
  memberId  String
  role      MemberClubRole
  createdAt DateTime       @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, role])
}

/// Rôle « libellé » défini par le club (ex. bénévole, compétiteur). Les rôles
/// système STUDENT / COACH / BOARD restent sur MemberRoleAssignment (enum).
model ClubRoleDefinition {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club        Club                         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  assignments MemberCustomRoleAssignment[]

  @@index([clubId])
}

model MemberCustomRoleAssignment {
  id               String   @id @default(uuid())
  memberId         String
  roleDefinitionId String
  createdAt        DateTime @default(now())

  member         Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  roleDefinition ClubRoleDefinition @relation(fields: [roleDefinitionId], references: [id], onDelete: Restrict)

  @@unique([memberId, roleDefinitionId])
  @@index([roleDefinitionId])
}

model DynamicGroup {
  id        String   @id @default(uuid())
  clubId    String
  name      String
  minAge    Int?
  maxAge    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club              Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gradeFilters      DynamicGroupGradeLevel[]
  courseSlots       CourseSlot[]
  messageCampaigns  MessageCampaign[]
  memberAssignments MemberDynamicGroup[]
  invoiceLines      InvoiceLine[]
  chatRoomScopes    ChatRoomMembershipScope[]

  @@index([clubId])
}

model DynamicGroupGradeLevel {
  dynamicGroupId String
  gradeLevelId   String

  dynamicGroup DynamicGroup @relation(fields: [dynamicGroupId], references: [id], onDelete: Cascade)
  gradeLevel   GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@id([dynamicGroupId, gradeLevelId])
}

// --- Module Familles (foyer, payeur unique, profils visionneur) ---

enum FamilyMemberLinkRole {
  PAYER
  MEMBER
}

model Family {
  id               String   @id @default(uuid())
  clubId           String
  label            String?
  householdGroupId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  club                     Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  householdGroup           HouseholdGroup?  @relation("FamilyInHouseholdGroup", fields: [householdGroupId], references: [id], onDelete: SetNull)
  carrierForHouseholdGroup HouseholdGroup?  @relation("HouseholdGroupCarrier")
  familyMembers            FamilyMember[]
  invoices                 Invoice[]
  invites                  FamilyInvite[]
  membershipCarts          MembershipCart[]

  @@index([clubId])
  @@index([householdGroupId])
}

/// Rôle proposé par le payeur à l'invité dans une invitation FamilyInvite.
enum FamilyInviteRole {
  COPAYER
  VIEWER
}

/// Invitation nominative envoyée par un payeur à un proche pour rejoindre son foyer (spec 2026-04-19).
model FamilyInvite {
  id               String           @id @default(uuid())
  clubId           String
  familyId         String
  createdByUserId  String
  role             FamilyInviteRole
  code             String           @unique @db.VarChar(16)
  tokenHash        String
  expiresAt        DateTime
  consumedAt       DateTime?
  consumedByUserId String?
  createdAt        DateTime         @default(now())

  /// Email du destinataire si l'invitation a été envoyée par mail.
  /// Permet au destinataire de voir ses invitations en attente dès qu'il
  /// se connecte (pas besoin de passer par le mail reçu). Normalisé en
  /// lowercase + trim avant insertion.
  recipientEmail String?

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([familyId])
  @@index([recipientEmail])
}

/// Foyer étendu : plusieurs `Family` (résidences) partagent facturation et enfants (spec 2026-03-31).
model HouseholdGroup {
  id              String   @id @default(uuid())
  clubId          String
  label           String?
  /// Foyer porteur transitoire pour factures encore rattachées à `Invoice.familyId` (spec §6.1).
  carrierFamilyId String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  club          Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  families      Family[]  @relation("FamilyInHouseholdGroup")
  carrierFamily Family?   @relation("HouseholdGroupCarrier", fields: [carrierFamilyId], references: [id], onDelete: SetNull)
  invoices      Invoice[]

  @@index([clubId])
}

/// Lien foyer ↔ personne : `MEMBER` → `memberId` requis ; `PAYER` → `memberId` ou `contactId` (exactement un des deux).
model FamilyMember {
  id        String               @id @default(uuid())
  familyId  String
  memberId  String?
  contactId String?
  linkRole  FamilyMemberLinkRole @default(MEMBER)
  createdAt DateTime             @default(now())

  family  Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member  Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contact Contact? @relation("FamilyMemberPayerContact", fields: [contactId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([contactId])
}

// --- Module Planning (créneaux, lieux, conflits professeur) ---

model Venue {
  id          String   @id @default(uuid())
  clubId      String
  name        String
  addressLine String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
