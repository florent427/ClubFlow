generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Club {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// URL (ou chemin statique relatif /uploads/...) du logo imprimé sur les factures.
  logoUrl       String?
  /// SIRET du club (facultatif, affiché en pied de facture PDF).
  siret         String?
  /// Adresse complète postale, multi-ligne séparées par `\n`.
  address       String?
  /// Mentions légales en pied de facture (TVA non applicable, association loi 1901…).
  legalMentions String?
  /// Téléphone de contact du club affiché sur l'en-tête de facture.
  contactPhone  String?
  /// E-mail de contact du club affiché sur l'en-tête de facture.
  contactEmail  String?

  memberships     ClubMembership[]
  modules         ClubModule[]
  gradeLevels     GradeLevel[]
  roleDefinitions ClubRoleDefinition[]
  members         Member[]
  dynamicGroups   DynamicGroup[]
  families        Family[]
  householdGroups HouseholdGroup[]
  venues          Venue[]
  courseSlots     CourseSlot[]

  pricingRules                    ClubPricingRule[]
  invoices                        Invoice[]
  payments                        Payment[]
  messageCampaigns                MessageCampaign[]
  accountingEntries               AccountingEntry[]
  grantApplications               GrantApplication[]
  sponsorshipDeals                SponsorshipDeal[]
  memberFieldCatalogSettings      ClubMemberFieldCatalogSetting[]
  memberCustomFieldDefinitions    MemberCustomFieldDefinition[]
  clubSeasons                     ClubSeason[]
  membershipProducts              MembershipProduct[]
  membershipOneTimeFees           MembershipOneTimeFee[]
  sendingDomains                  ClubSendingDomain[]
  emailSuppressions               EmailSuppression[]
  contacts                        Contact[]
  chatRooms                       ChatRoom[]
  membershipCarts                 MembershipCart[]
  /// À partir du n-ième bulletin d’adhésion (OPEN/PAID) pour le foyer sur la saison — null = désactivé
  membershipFamilyDiscountFromNth Int?
  membershipFamilyAdjustmentType  PricingAdjustmentType           @default(NONE)
  membershipFamilyAdjustmentValue Int                             @default(0)

  /// Domaine personnalisé pour le site vitrine public (ex. www.mondojo.fr).
  /// CNAME à poser vers le serveur Next.js ; HTTPS géré par le reverse-proxy.
  customDomain     String? @unique
  /// Flag « site vitrine publié ». Quand false, le site renvoie 404 publique
  /// (seuls les aperçus admin restent accessibles).
  vitrinePublished Boolean @default(false)

  /// Tagline affichée sous le nom du club dans la nav et le footer.
  /// Ex. "空手道 · Sud Réunion" pour un dojo.
  vitrineKanjiTagline String?

  /// JSON sérialisé du contenu de footer (colonnes, contact, social, bottom).
  /// Si null, fallback hard-codé côté vitrine pour ne jamais casser le rendu.
  vitrineFooterJson Json?

  /// Palette couleurs personnalisée du site vitrine (JSON).
  /// Schéma : { ink, ink2, paper, accent, goldBright, vermillion, line, muted }
  /// Si null → palette SKSR par défaut côté vitrine.
  vitrinePaletteJson Json?

  /// Typographies personnalisées du site vitrine (JSON).
  /// Schéma : { serif, sans, jp }  — chaque clé est le nom d'une police Google Fonts.
  /// Si null → fonts SKSR par défaut (Cormorant/Inter/Shippori Mincho).
  vitrineFontsJson   Json?

  vitrinePages         VitrinePage[]
  vitrineArticles      VitrineArticle[]
  vitrineAnnouncements VitrineAnnouncement[]
  vitrineGalleryPhotos VitrineGalleryPhoto[]
  vitrineCategories    VitrineCategory[]
  mediaAssets          MediaAsset[]
  clubProjects         ClubProject[]
  distributionLists    DistributionList[]

  /// Clé API OpenRouter (chiffrée AES-256-GCM, base64).
  /// null = fonctionnalités IA désactivées pour ce club.
  aiOpenrouterApiKeyEnc String?

  /// Modèle texte (ex. anthropic/claude-sonnet-4-5).
  aiTextModel String?

  /// Modèle texte de fallback (utilisé si le primaire échoue 3× sur un tool
  /// call ou renvoie une erreur 5xx/timeout). Null = pas de fallback.
  aiTextFallbackModel String?

  /// Modèle image (ex. google/gemini-2.5-flash-image-preview).
  aiImageModel String?

  /// Compteurs cumulés de consommation IA.
  aiTokensInputUsed  BigInt @default(0)
  aiTokensOutputUsed BigInt @default(0)
  aiImagesGenerated  Int    @default(0)

  aiUsageLogs AiUsageLog[]

  /// Feature flag : agent conversationnel activé pour ce club.
  /// Même si true, peut être désactivé globalement via env AGENT_GLOBAL_KILLED=true.
  agentEnabled Boolean @default(true)

  agentConversations AgentConversation[]
  agentPendingActions AgentPendingAction[]
}

enum AiUsageFeature {
  ARTICLE_GENERATION
  IMAGE_GENERATION
  AGENT_CHAT
  /// Modération IA des items live uploadés par les contributeurs projet
  /// (vision pertinence + qualité).
  PROJECT_MODERATION
  /// Génération de comptes-rendus projet (3 presets : COMPETITIF, FESTIF,
  /// BILAN) via le module Projets.
  PROJECT_REPORT
  OTHER
}

enum AgentMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum AgentToolCallStatus {
  PENDING_CONFIRMATION
  EXECUTED
  REFUSED
  FAILED
  BLOCKED_BY_LIMITS
  BLOCKED_BY_SCOPE
}

enum AgentRiskLevel {
  SAFE
  GUARDED
  DESTRUCTIVE
  FORBIDDEN
}

/// Conversation ouverte par un utilisateur avec l'agent.
model AgentConversation {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  /// Scope projet : si non null, la conversation est cantonnée au projet X,
  /// seuls les outils `scope = 'PROJECT'` seront exposés à l'agent + le
  /// system prompt est enrichi du contexte projet (titre, contributeurs,
  /// items live récents). Null = agent club classique (portée historique).
  projectId String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archived  Boolean  @default(false)

  club     Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  project  ClubProject?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([clubId, userId, updatedAt])
  @@index([projectId])
}

/// Message individuel dans une conversation (user, assistant, tool result).
model AgentMessage {
  id             String           @id @default(uuid())
  conversationId String
  role           AgentMessageRole
  /// Texte pour role=USER|ASSISTANT|SYSTEM. Pour role=TOOL, JSON résultat.
  content        String
  /// Résumé token usage quand role=ASSISTANT.
  inputTokens    Int?
  outputTokens   Int?
  model          String?
  /// Pièces jointes du message (images, PDF, docs). JSON array :
  /// [{ mediaAssetId, kind: 'IMAGE'|'DOCUMENT', mimeType, fileName, publicUrl, extractedText? }]
  /// Seuls les USER messages en utilisent.
  attachmentsJson Json?
  createdAt      DateTime         @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls    AgentToolCall[]

  @@index([conversationId, createdAt])
}

/// Un appel de tool requested par le LLM, avec son résultat ou son état.
model AgentToolCall {
  id              String              @id @default(uuid())
  messageId       String
  toolName        String
  argsJson        Json
  riskLevel       AgentRiskLevel
  status          AgentToolCallStatus
  /// JSON du résultat d'exécution (seulement si status=EXECUTED).
  resultJson      Json?
  errorMessage    String?
  /// Si pending confirmation, lien vers le PendingAction.
  pendingActionId String?
  createdAt       DateTime            @default(now())
  executedAt      DateTime?

  message AgentMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
}

/// Action en attente de confirmation humaine (destructive/guarded).
/// Signée anti-replay, expire en 5 min.
model AgentPendingAction {
  id              String   @id @default(uuid())
  clubId          String
  userId          String
  conversationId  String
  toolName        String
  argsJson        Json
  riskLevel       AgentRiskLevel
  /// Preview en français de l'action (affichée à l'utilisateur).
  previewText     String
  /// Signature HMAC pour anti-replay.
  signature       String
  status          AgentToolCallStatus @default(PENDING_CONFIRMATION)
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  resolvedAt      DateTime?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, userId, status])
  @@index([expiresAt])
}

/// Historique des appels IA (un par mutation).
model AiUsageLog {
  id              String         @id @default(uuid())
  clubId          String
  feature         AiUsageFeature
  model           String
  inputTokens     Int            @default(0)
  outputTokens    Int            @default(0)
  imagesGenerated Int            @default(0)
  /// Coût en cents (si disponible dans la réponse OpenRouter).
  costCents       Int?
  userId          String?
  createdAt       DateTime       @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
}

enum MembershipRole {
  CLUB_ADMIN
  BOARD
  COACH
  TREASURER
  SECRETARY
  STAFF
  /// Responsable communication — accès délégué à l'éditorial du site
  /// vitrine (pages, articles, annonces, galerie, médias) sans les droits
  /// financiers/administratifs complets.
  COMM_MANAGER
  /// Chef de projet — peut créer, administrer et archiver des ClubProject
  /// sans avoir tous les droits CLUB_ADMIN. Ne donne PAS accès aux autres
  /// modules (compta, membres hors projet, paramètres club).
  PROJECT_MANAGER
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?
  emailVerifiedAt DateTime?
  displayName     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships             ClubMembership[]
  tokens                  RefreshToken[]
  members                 Member[]
  contacts                Contact[]
  userIdentities          UserIdentity[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

enum OAuthProvider {
  GOOGLE
  FACEBOOK
  LINKEDIN
}

/// Prospect / contact portail — distinct du membre adhérent (`Member`)
model Contact {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  firstName String
  lastName  String
  phone     String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club                   Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Liens `FamilyMember` où ce contact est désigné payeur (`linkRole = PAYER`).
  familyMemberPayerLinks FamilyMember[]   @relation("FamilyMemberPayerContact")
  paymentsAsPaidBy       Payment[]        @relation("PaymentPaidByContact")
  membershipCartsAsPayer MembershipCart[] @relation("CartPayerContact")
  projectContributions   ProjectContributor[]

  @@unique([userId, clubId])
}

model UserIdentity {
  id              String        @id @default(uuid())
  userId          String
  provider        OAuthProvider
  providerSubject String
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ClubMembership {
  id        String         @id @default(uuid())
  userId    String
  clubId    String
  role      MembershipRole @default(STAFF)
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

model ModuleDefinition {
  code        String       @id
  label       String
  isRequired  Boolean      @default(false)
  description String?
  clubModules ClubModule[]
}

model ClubModule {
  id         String    @id @default(uuid())
  clubId     String
  moduleCode String
  enabled    Boolean   @default(false)
  enabledAt  DateTime?
  disabledAt DateTime?

  club   Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  module ModuleDefinition @relation(fields: [moduleCode], references: [code], onDelete: Restrict)

  @@unique([clubId, moduleCode])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Module Membres (référentiel adhérents + grades + groupes dynamiques) ---

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum MemberClubRole {
  STUDENT
  COACH
  BOARD
}

enum MemberCivility {
  MR
  MME
}

/// Champs « catalogue » (colonnes Member) configurables sur la fiche admin
enum MemberCatalogFieldKey {
  PHONE
  ADDRESS_LINE
  POSTAL_CODE
  CITY
  BIRTH_DATE
  PHOTO_URL
  MEDICAL_CERT_EXPIRES_AT
  GRADE_LEVEL
}

enum MemberCustomFieldType {
  TEXT
  TEXT_LONG
  NUMBER
  DATE
  BOOLEAN
  SELECT
}

model ClubMemberFieldCatalogSetting {
  id         String                @id @default(uuid())
  clubId     String
  fieldKey   MemberCatalogFieldKey
  showOnForm Boolean               @default(true)
  required   Boolean               @default(false)
  sortOrder  Int                   @default(0)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, fieldKey])
  @@index([clubId])
}

model MemberCustomFieldDefinition {
  id              String                @id @default(uuid())
  clubId          String
  code            String
  label           String
  type            MemberCustomFieldType
  required        Boolean               @default(false)
  sortOrder       Int                   @default(0)
  visibleToMember Boolean               @default(false)
  optionsJson     String?
  archivedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  club   Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  values MemberCustomFieldValue[]

  @@unique([clubId, code])
  @@index([clubId])
}

model MemberCustomFieldValue {
  id           String   @id @default(uuid())
  memberId     String
  definitionId String
  valueText    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  member     Member                      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  definition MemberCustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([memberId, definitionId])
  @@index([memberId])
  @@index([definitionId])
}

model GradeLevel {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club                         Club                          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members                      Member[]
  dynamicGroupGradeLevels      DynamicGroupGradeLevel[]
  membershipProductGradeLevels MembershipProductGradeLevel[]

  @@index([clubId])
}

model Member {
  id                   String         @id @default(uuid())
  clubId               String
  userId               String?
  firstName            String
  lastName             String
  /// Pseudo messagerie ; unique par club ; [a-z0-9_]
  pseudo               String         @db.VarChar(64)
  civility             MemberCivility
  email                String
  phone                String?
  addressLine          String?
  postalCode           String?
  city                 String?
  birthDate            DateTime?
  photoUrl             String?
  medicalCertExpiresAt DateTime?
  status               MemberStatus   @default(ACTIVE)
  gradeLevelId         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  club                      Club                         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user                      User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  gradeLevel                GradeLevel?                  @relation(fields: [gradeLevelId], references: [id], onDelete: SetNull)
  roleAssignments           MemberRoleAssignment[]
  customRoleAssignments     MemberCustomRoleAssignment[]
  familyMembers             FamilyMember[]
  courseSlotsAsCoach        CourseSlot[]                 @relation("CourseSlotCoach")
  courseSlotBookings        CourseSlotBooking[]          @relation("CourseSlotBookingMember")
  messageCampaignRecipients MessageCampaignRecipient[]
  customFieldValues         MemberCustomFieldValue[]
  dynamicGroupAssignments   MemberDynamicGroup[]
  invoiceLines              InvoiceLine[]
  paymentsAsPaidBy          Payment[]                    @relation("PaymentPaidByMember")
  telegramChatId            String?                      @map("telegram_chat_id")
  telegramLinkedAt          DateTime?                    @map("telegram_linked_at")
  telegramLinkTokens        TelegramLinkToken[]
  chatRoomMemberships       ChatRoomMember[]
  chatMessagesSent          ChatMessage[]                @relation("ChatMessageSender")
  chatRoomsCreated          ChatRoom[]                   @relation("MemberChatRoomsCreated")

  /// Numéro de licence fédérale validé (saisi une fois via « J'ai déjà une licence »).
  licenseNumber          String?
  membershipCartItems    MembershipCartItem[]
  membershipCartsAsPayer MembershipCart[]     @relation("CartPayerMember")
  projectContributions   ProjectContributor[]

  @@unique([clubId, userId])
  @@unique([clubId, pseudo])
  @@index([clubId])
  @@index([clubId, status])
}

enum ChatRoomKind {
  DIRECT
  GROUP
  COMMUNITY
}

enum ChatRoomMemberRole {
  MEMBER
  ADMIN
}

model ChatRoom {
  id                String       @id @default(uuid())
  clubId            String
  kind              ChatRoomKind
  name              String?
  directPairKey     String?      @unique
  createdByMemberId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  club     Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator  Member?          @relation("MemberChatRoomsCreated", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  members  ChatRoomMember[]
  messages ChatMessage[]

  @@index([clubId, kind])
}

model ChatRoomMember {
  id       String             @id @default(uuid())
  roomId   String
  memberId String
  role     ChatRoomMemberRole @default(MEMBER)
  joinedAt DateTime           @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  member Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([roomId, memberId])
  @@index([memberId])
}

model ChatMessage {
  id             String    @id @default(uuid())
  roomId         String
  senderMemberId String
  body           String    @db.Text
  createdAt      DateTime  @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender Member   @relation("ChatMessageSender", fields: [senderMemberId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

/// Jeton ponctuel pour `t.me/Bot?start=TOKEN` — lie le chat Telegram au membre.
model TelegramLinkToken {
  id         String    @id @default(uuid())
  clubId     String
  memberId   String
  token      String    @unique @db.VarChar(64)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([token])
}

model MemberRoleAssignment {
  id        String         @id @default(uuid())
  memberId  String
  role      MemberClubRole
  createdAt DateTime       @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, role])
}

/// Rôle « libellé » défini par le club (ex. bénévole, compétiteur). Les rôles
/// système STUDENT / COACH / BOARD restent sur MemberRoleAssignment (enum).
model ClubRoleDefinition {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club        Club                         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  assignments MemberCustomRoleAssignment[]

  @@index([clubId])
}

model MemberCustomRoleAssignment {
  id               String   @id @default(uuid())
  memberId         String
  roleDefinitionId String
  createdAt        DateTime @default(now())

  member         Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  roleDefinition ClubRoleDefinition @relation(fields: [roleDefinitionId], references: [id], onDelete: Restrict)

  @@unique([memberId, roleDefinitionId])
  @@index([roleDefinitionId])
}

model DynamicGroup {
  id        String   @id @default(uuid())
  clubId    String
  name      String
  minAge    Int?
  maxAge    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club              Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gradeFilters      DynamicGroupGradeLevel[]
  courseSlots       CourseSlot[]
  messageCampaigns  MessageCampaign[]
  memberAssignments MemberDynamicGroup[]
  invoiceLines      InvoiceLine[]

  @@index([clubId])
}

model DynamicGroupGradeLevel {
  dynamicGroupId String
  gradeLevelId   String

  dynamicGroup DynamicGroup @relation(fields: [dynamicGroupId], references: [id], onDelete: Cascade)
  gradeLevel   GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@id([dynamicGroupId, gradeLevelId])
}

// --- Module Familles (foyer, payeur unique, profils visionneur) ---

enum FamilyMemberLinkRole {
  PAYER
  MEMBER
}

model Family {
  id               String   @id @default(uuid())
  clubId           String
  label            String?
  householdGroupId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  club                     Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  householdGroup           HouseholdGroup?  @relation("FamilyInHouseholdGroup", fields: [householdGroupId], references: [id], onDelete: SetNull)
  carrierForHouseholdGroup HouseholdGroup?  @relation("HouseholdGroupCarrier")
  familyMembers            FamilyMember[]
  invoices                 Invoice[]
  invites                  FamilyInvite[]
  membershipCarts          MembershipCart[]

  @@index([clubId])
  @@index([householdGroupId])
}

/// Rôle proposé par le payeur à l'invité dans une invitation FamilyInvite.
enum FamilyInviteRole {
  COPAYER
  VIEWER
}

/// Invitation nominative envoyée par un payeur à un proche pour rejoindre son foyer (spec 2026-04-19).
model FamilyInvite {
  id               String           @id @default(uuid())
  clubId           String
  familyId         String
  createdByUserId  String
  role             FamilyInviteRole
  code             String           @unique @db.VarChar(16)
  tokenHash        String
  expiresAt        DateTime
  consumedAt       DateTime?
  consumedByUserId String?
  createdAt        DateTime         @default(now())

  /// Email du destinataire si l'invitation a été envoyée par mail.
  /// Permet au destinataire de voir ses invitations en attente dès qu'il
  /// se connecte (pas besoin de passer par le mail reçu). Normalisé en
  /// lowercase + trim avant insertion.
  recipientEmail String?

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([familyId])
  @@index([recipientEmail])
}

/// Foyer étendu : plusieurs `Family` (résidences) partagent facturation et enfants (spec 2026-03-31).
model HouseholdGroup {
  id              String   @id @default(uuid())
  clubId          String
  label           String?
  /// Foyer porteur transitoire pour factures encore rattachées à `Invoice.familyId` (spec §6.1).
  carrierFamilyId String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  club          Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  families      Family[]  @relation("FamilyInHouseholdGroup")
  carrierFamily Family?   @relation("HouseholdGroupCarrier", fields: [carrierFamilyId], references: [id], onDelete: SetNull)
  invoices      Invoice[]

  @@index([clubId])
}

/// Lien foyer ↔ personne : `MEMBER` → `memberId` requis ; `PAYER` → `memberId` ou `contactId` (exactement un des deux).
model FamilyMember {
  id        String               @id @default(uuid())
  familyId  String
  memberId  String?
  contactId String?
  linkRole  FamilyMemberLinkRole @default(MEMBER)
  createdAt DateTime             @default(now())

  family  Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member  Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contact Contact? @relation("FamilyMemberPayerContact", fields: [contactId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([contactId])
}

// --- Module Planning (créneaux, lieux, conflits professeur) ---

model Venue {
  id          String   @id @default(uuid())
  clubId      String
  name        String
  addressLine String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  courseSlots CourseSlot[]

  @@index([clubId])
}

model CourseSlot {
  id              String    @id @default(uuid())
  clubId          String
  venueId         String
  coachMemberId   String
  title           String
  startsAt        DateTime
  endsAt          DateTime
  dynamicGroupId  String?
  bookingEnabled  Boolean   @default(false)
  bookingCapacity Int?
  bookingOpensAt  DateTime?
  bookingClosesAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  club         Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  venue        Venue               @relation(fields: [venueId], references: [id], onDelete: Restrict)
  coachMember  Member              @relation("CourseSlotCoach", fields: [coachMemberId], references: [id], onDelete: Restrict)
  dynamicGroup DynamicGroup?       @relation(fields: [dynamicGroupId], references: [id], onDelete: SetNull)
  bookings     CourseSlotBooking[]

  @@index([clubId, coachMemberId])
  @@index([clubId, startsAt])
}

enum CourseSlotBookingStatus {
  BOOKED
  WAITLISTED
  CANCELLED
}

model CourseSlotBooking {
  id           String                  @id @default(uuid())
  courseSlotId String
  memberId     String
  status       CourseSlotBookingStatus @default(BOOKED)
  bookedAt     DateTime                @default(now())
  cancelledAt  DateTime?
  note         String?                 @db.VarChar(500)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  courseSlot CourseSlot @relation(fields: [courseSlotId], references: [id], onDelete: Cascade)
  member     Member     @relation("CourseSlotBookingMember", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([courseSlotId, memberId])
  @@index([courseSlotId])
  @@index([memberId])
}

// --- Adhésion : saisons, groupes persistés, formules, lignes de facture ---

model ClubSeason {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  startsOn  DateTime @db.Date
  endsOn    DateTime @db.Date
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club            Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  membershipCarts MembershipCart[]

  @@index([clubId])
}

model MemberDynamicGroup {
  id             String   @id @default(uuid())
  clubId         String
  memberId       String
  dynamicGroupId String
  createdAt      DateTime @default(now())

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  dynamicGroup DynamicGroup @relation(fields: [dynamicGroupId], references: [id], onDelete: Cascade)

  @@unique([memberId, dynamicGroupId])
  @@index([clubId, memberId])
}

model MembershipProduct {
  id                      String    @id @default(uuid())
  clubId                  String
  label                   String
  annualAmountCents       Int
  monthlyAmountCents      Int
  minAge                  Int?
  maxAge                  Int?
  allowProrata            Boolean   @default(true)
  allowFamily             Boolean   @default(true)
  allowPublicAid          Boolean   @default(true)
  allowExceptional        Boolean   @default(true)
  exceptionalCapPercentBp Int?
  archivedAt              DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  club         Club                          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gradeFilters MembershipProductGradeLevel[]
  invoiceLines InvoiceLine[]
  cartItems    MembershipCartItem[]

  @@index([clubId])
}

model MembershipProductGradeLevel {
  membershipProductId String
  gradeLevelId        String

  membershipProduct MembershipProduct @relation(fields: [membershipProductId], references: [id], onDelete: Cascade)
  gradeLevel        GradeLevel        @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@id([membershipProductId, gradeLevelId])
}

enum MembershipOneTimeFeeKind {
  /// Licence fédérale. Skipée automatiquement si le membre coche « j'ai déjà une licence ».
  LICENSE
  /// Frais obligatoire (cotisation club, kit équipement...). Toujours ajouté.
  MANDATORY
  /// Frais optionnel. Ajouté uniquement si sélectionné manuellement.
  OPTIONAL
}

model MembershipOneTimeFee {
  id          String                   @id @default(uuid())
  clubId      String
  label       String
  amountCents Int
  /// Classification fonctionnelle ; pilote l'auto-ajout au panier d'adhésion.
  kind        MembershipOneTimeFeeKind @default(OPTIONAL)
  /// Ajouté automatiquement à chaque item du panier d'adhésion créé.
  autoApply   Boolean                  @default(false)
  archivedAt  DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoiceLines InvoiceLine[]

  @@index([clubId])
}

enum InvoiceLineKind {
  MEMBERSHIP_SUBSCRIPTION
  MEMBERSHIP_ONE_TIME
}

enum SubscriptionBillingRhythm {
  ANNUAL
  MONTHLY
}

enum InvoiceLineAdjustmentType {
  PRORATA_SEASON
  FAMILY
  PUBLIC_AID
  EXCEPTIONAL
}

model InvoiceLine {
  id                        String                     @id @default(uuid())
  invoiceId                 String
  kind                      InvoiceLineKind            @default(MEMBERSHIP_SUBSCRIPTION)
  memberId                  String
  membershipProductId       String?
  membershipOneTimeFeeId    String?
  subscriptionBillingRhythm SubscriptionBillingRhythm?
  dynamicGroupId            String?
  baseAmountCents           Int
  sortOrder                 Int                        @default(0)

  invoice              Invoice                 @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  member               Member                  @relation(fields: [memberId], references: [id], onDelete: Restrict)
  membershipProduct    MembershipProduct?      @relation(fields: [membershipProductId], references: [id], onDelete: SetNull)
  membershipOneTimeFee MembershipOneTimeFee?   @relation(fields: [membershipOneTimeFeeId], references: [id], onDelete: SetNull)
  dynamicGroup         DynamicGroup?           @relation(fields: [dynamicGroupId], references: [id], onDelete: SetNull)
  adjustments          InvoiceLineAdjustment[]

  @@index([invoiceId])
  @@index([memberId])
}

model InvoiceLineAdjustment {
  id               String                    @id @default(uuid())
  lineId           String
  stepOrder        Int
  type             InvoiceLineAdjustmentType
  amountCents      Int
  percentAppliedBp Int?
  metadataJson     String?
  reason           String?
  createdByUserId  String?

  line InvoiceLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@index([lineId])
}

// --- Phase E : Paiement (factures, encaissements, tarification, Stripe) ---

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

enum ClubPaymentMethod {
  STRIPE_CARD
  MANUAL_CASH
  MANUAL_CHECK
  MANUAL_TRANSFER
}

enum PricingAdjustmentType {
  NONE
  PERCENT_BP
  FIXED_CENTS
}

model ClubPricingRule {
  id              String                @id @default(uuid())
  clubId          String
  method          ClubPaymentMethod
  adjustmentType  PricingAdjustmentType @default(NONE)
  adjustmentValue Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, method])
  @@index([clubId])
}

model Invoice {
  id                    String             @id @default(uuid())
  clubId                String
  familyId              String?
  householdGroupId      String?
  clubSeasonId          String?
  label                 String
  baseAmountCents       Int
  amountCents           Int
  status                InvoiceStatus      @default(OPEN)
  lockedPaymentMethod   ClubPaymentMethod?
  dueAt                 DateTime?
  stripePaymentIntentId String?            @unique
  /// Dernière date d'envoi d'un e-mail de relance pour cette facture.
  lastRemindedAt        DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  /// true si ce document est un AVOIR (contre-facture) — montant cents reste positif côté modèle,
  /// inversé à l'affichage et en comptabilité.
  isCreditNote     Boolean @default(false)
  /// Pour un avoir : id de la facture source (qui est remboursée/annulée partiellement).
  parentInvoiceId  String?
  /// Motif textuel affiché sur l'avoir (« erreur de saisie », « remboursement cotisation »…)
  creditNoteReason String?

  club           Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  family         Family?         @relation(fields: [familyId], references: [id], onDelete: SetNull)
  householdGroup HouseholdGroup? @relation(fields: [householdGroupId], references: [id], onDelete: SetNull)
  clubSeason     ClubSeason?     @relation(fields: [clubSeasonId], references: [id], onDelete: SetNull)
  lines          InvoiceLine[]
  payments       Payment[]
  membershipCart MembershipCart?

  parentInvoice Invoice?  @relation("InvoiceCreditNotes", fields: [parentInvoiceId], references: [id], onDelete: SetNull)
  creditNotes   Invoice[] @relation("InvoiceCreditNotes")

  @@index([clubId, status])
  @@index([clubId, householdGroupId, status])
  @@index([clubSeasonId])
  @@index([parentInvoiceId])
}

model Payment {
  id              String            @id @default(uuid())
  clubId          String
  invoiceId       String
  amountCents     Int
  method          ClubPaymentMethod
  externalRef     String?
  /// Payeur réel (portail / traçabilité). Null = encaissement club catalogué sans fiche membre payeur.
  paidByMemberId  String?
  /// Payeur contact (sans fiche `Member`). Au plus un de `paidByMemberId` / `paidByContactId` (appli).
  paidByContactId String?
  createdAt       DateTime          @default(now())

  club              Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoice           Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  paidByMember      Member?           @relation("PaymentPaidByMember", fields: [paidByMemberId], references: [id], onDelete: SetNull)
  paidByContact     Contact?          @relation("PaymentPaidByContact", fields: [paidByContactId], references: [id], onDelete: SetNull)
  accountingEntries AccountingEntry[]

  @@index([clubId, createdAt])
  @@index([invoiceId])
  @@index([paidByMemberId])
  @@index([paidByContactId])
}

model StripeWebhookEvent {
  id          String   @id
  processedAt DateTime @default(now())
}

// --- Phase F : Communication (campagnes, audience = groupes dynamiques) ---

enum CommunicationChannel {
  EMAIL
  TELEGRAM
  PUSH
}

enum MessageCampaignStatus {
  DRAFT
  SENT
}

model MessageCampaign {
  id             String                @id @default(uuid())
  clubId         String
  title          String
  body           String
  channel        CommunicationChannel
  dynamicGroupId String?
  /// Rattachement optionnel à un ClubProject (pour le futur module
  /// Communications scopé projet + traçabilité analytique).
  projectId      String?
  status         MessageCampaignStatus @default(DRAFT)
  sentAt         DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  club         Club                       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  dynamicGroup DynamicGroup?              @relation(fields: [dynamicGroupId], references: [id], onDelete: SetNull)
  project      ClubProject?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  recipients   MessageCampaignRecipient[]

  @@index([clubId])
  @@index([projectId])
}

model MessageCampaignRecipient {
  id         String   @id @default(uuid())
  campaignId String
  memberId   String
  createdAt  DateTime @default(now())

  campaign MessageCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  member   Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([campaignId, memberId])
  @@index([memberId])
}

/// Domaine d’envoi e-mail du club (ESP + statut DNS).
enum ClubSendingDomainPurpose {
  TRANSACTIONAL
  CAMPAIGN
  BOTH
}

enum ClubSendingDomainVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

model ClubSendingDomain {
  id                 String                              @id @default(uuid())
  clubId             String
  fqdn               String
  purpose            ClubSendingDomainPurpose
  verificationStatus ClubSendingDomainVerificationStatus @default(PENDING)
  providerDomainId   String?
  dnsRecordsJson     String?
  lastCheckedAt      DateTime?
  createdAt          DateTime                            @default(now())
  updatedAt          DateTime                            @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, fqdn])
  @@index([clubId])
}

/// Adresses exclues des campagnes (bounce dur, plainte ESP).
model EmailSuppression {
  id              String   @id @default(uuid())
  clubId          String
  emailNormalized String
  reason          String
  createdAt       DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, emailNormalized])
  @@index([clubId])
}

// --- Phase G : Comptabilité (écritures) + stubs Subventions / Sponsoring ---

enum AccountingEntryKind {
  INCOME
  EXPENSE
}

model AccountingEntry {
  id          String              @id @default(uuid())
  clubId      String
  kind        AccountingEntryKind
  label       String
  amountCents Int
  paymentId   String?
  /// Rattachement analytique optionnel à un ClubProject. Null = écriture
  /// générale club. Permet de projeter un P&L par projet une fois le
  /// module compta activé.
  projectId   String?
  occurredAt  DateTime            @default(now())
  createdAt   DateTime            @default(now())

  club    Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  payment Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  project ClubProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clubId, occurredAt])
  @@index([clubId, projectId])
}

enum GrantApplicationStatus {
  DRAFT
  SUBMITTED
  ARCHIVED
}

model GrantApplication {
  id          String                 @id @default(uuid())
  clubId      String
  title       String
  status      GrantApplicationStatus @default(DRAFT)
  amountCents Int?
  notes       String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
}

enum SponsorshipDealStatus {
  ACTIVE
  CLOSED
}

model SponsorshipDeal {
  id          String                @id @default(uuid())
  clubId      String
  sponsorName String
  amountCents Int?
  status      SponsorshipDealStatus @default(ACTIVE)
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
}

enum ClubSurveyStatus {
  DRAFT
  OPEN
  CLOSED
}

model ClubAnnouncement {
  id           String    @id @default(uuid())
  clubId       String
  authorUserId String
  title        String
  body         String
  pinned       Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([clubId, publishedAt])
  @@index([clubId, pinned])
}

model ClubSurvey {
  id             String           @id @default(uuid())
  clubId         String
  authorUserId   String
  title          String
  description    String?
  status         ClubSurveyStatus @default(DRAFT)
  multipleChoice Boolean          @default(false)
  allowAnonymous Boolean          @default(false)
  publishedAt    DateTime?
  closesAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  options   ClubSurveyOption[]
  responses ClubSurveyResponse[]

  @@index([clubId, status])
}

model ClubSurveyOption {
  id        String   @id @default(uuid())
  surveyId  String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  survey    ClubSurvey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  responses ClubSurveyResponse[]

  @@index([surveyId])
}

model ClubSurveyResponse {
  id        String   @id @default(uuid())
  surveyId  String
  optionId  String
  memberId  String?
  contactId String?
  createdAt DateTime @default(now())

  survey ClubSurvey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  option ClubSurveyOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([surveyId, memberId, optionId])
  @@unique([surveyId, contactId, optionId])
  @@index([surveyId])
}

enum ClubEventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum ClubEventRegistrationStatus {
  REGISTERED
  WAITLISTED
  CANCELLED
}

model ClubEvent {
  id                       String          @id @default(uuid())
  clubId                   String
  /// Rattachement optionnel à un ClubProject (un projet peut regrouper N
  /// events datés — ex. « Gala 2026 » a une soirée + une répétition
  /// rattachées). Null = event autonome (cours hebdo, stage simple).
  projectId                String?
  title                    String
  description              String?
  location                 String?
  startsAt                 DateTime
  endsAt                   DateTime
  capacity                 Int?
  registrationOpensAt      DateTime?
  registrationClosesAt     DateTime?
  priceCents               Int?
  status                   ClubEventStatus @default(DRAFT)
  publishedAt              DateTime?
  allowContactRegistration Boolean         @default(false)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  project       ClubProject?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  registrations ClubEventRegistration[]
  attachments   ClubEventAttachment[]

  @@index([clubId, startsAt])
  @@index([clubId, status])
  @@index([projectId])
}

model ClubEventRegistration {
  id           String                      @id @default(uuid())
  eventId      String
  memberId     String?
  contactId    String?
  status       ClubEventRegistrationStatus @default(REGISTERED)
  registeredAt DateTime                    @default(now())
  cancelledAt  DateTime?
  note         String?

  event ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@unique([eventId, contactId])
  @@index([eventId, status])
}

/// Pièces jointes d'un événement (PDF, images…). Fichier stocké sur disque, métadonnées en base.
model ClubEventAttachment {
  id          String   @id @default(uuid())
  eventId     String
  fileName    String
  mimeType    String
  sizeBytes   Int
  storagePath String // chemin absolu sur disque — géré par EventAttachmentsService
  createdAt   DateTime @default(now())

  event ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ShopOrderStatus {
  PENDING
  PAID
  CANCELLED
}

model ShopProduct {
  id          String   @id @default(uuid())
  clubId      String
  sku         String?
  name        String
  description String?
  imageUrl    String?
  priceCents  Int
  stock       Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderLines ShopOrderLine[]

  @@index([clubId, active])
}

model ShopOrder {
  id         String          @id @default(uuid())
  clubId     String
  memberId   String?
  contactId  String?
  status     ShopOrderStatus @default(PENDING)
  totalCents Int
  note       String?         @db.VarChar(500)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  paidAt     DateTime?

  lines ShopOrderLine[]

  @@index([clubId, status])
  @@index([memberId])
  @@index([contactId])
}

model ShopOrderLine {
  id             String @id @default(uuid())
  orderId        String
  productId      String
  quantity       Int
  unitPriceCents Int
  label          String

  order   ShopOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product ShopProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model BlogPost {
  id            String         @id @default(uuid())
  clubId        String
  authorUserId  String
  slug          String
  title         String
  excerpt       String?        @db.VarChar(500)
  body          String
  coverImageUrl String?
  status        BlogPostStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([clubId, slug])
  @@index([clubId, status, publishedAt])
}

// --- Phase H : Projet d'adhésion (panier famille × saison) ---

enum MembershipCartStatus {
  /// Panier ouvert, modifiable librement. Un seul OPEN par (familyId, clubSeasonId).
  OPEN
  /// Panier validé → facture émise + email payeur envoyé. Immuable.
  VALIDATED
  /// Panier abandonné par le payeur (ou annulé par l'admin). Aucune facture générée.
  CANCELLED
}

/// Panier/projet d'adhésion d'une famille pour une saison. Accumule les items (membres + produit + licence + rythme + remises)
/// avant d'émettre la facture à la validation. Pas d'impact comptable tant que status != VALIDATED.
model MembershipCart {
  id              String               @id @default(uuid())
  clubId          String
  familyId        String
  clubSeasonId    String
  payerContactId  String?
  payerMemberId   String?
  status          MembershipCartStatus @default(OPEN)
  validatedAt     DateTime?
  invoiceId       String?              @unique
  cancelledReason String?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  club         Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  family       Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  clubSeason   ClubSeason           @relation(fields: [clubSeasonId], references: [id], onDelete: Cascade)
  payerContact Contact?             @relation("CartPayerContact", fields: [payerContactId], references: [id], onDelete: SetNull)
  payerMember  Member?              @relation("CartPayerMember", fields: [payerMemberId], references: [id], onDelete: SetNull)
  invoice      Invoice?             @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  items        MembershipCartItem[]

  @@index([clubId, status])
  @@index([familyId, clubSeasonId, status])
}

/// Item du panier = adhésion individuelle d'un membre pour la saison courante du cart.
/// Une ligne par membre, produit auto-sélectionné par âge (ou null si aucun produit ne matche).
model MembershipCartItem {
  id                        String                    @id @default(uuid())
  cartId                    String
  memberId                  String
  membershipProductId       String?
  billingRhythm             SubscriptionBillingRhythm @default(ANNUAL)
  hasExistingLicense        Boolean                   @default(false)
  existingLicenseNumber     String?
  exceptionalDiscountCents  Int                       @default(0)
  exceptionalDiscountReason String?
  /// true si aucun produit n'a matché l'âge du membre — admin doit assigner manuellement.
  requiresManualAssignment  Boolean                   @default(false)
  /// CSV des IDs de MembershipOneTimeFee forcés (override des autoApply défaut).
  /// Convention : si null → utiliser la liste des fees `autoApply=true` du club.
  /// Si présent → utiliser exactement cette liste.
  oneTimeFeeOverrideIdsCsv  String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  cart    MembershipCart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  member  Member             @relation(fields: [memberId], references: [id], onDelete: Restrict)
  product MembershipProduct? @relation(fields: [membershipProductId], references: [id], onDelete: SetNull)

  @@unique([cartId, memberId])
  @@index([cartId])
  @@index([memberId])
}

// ============================================================================
// Vitrine publique (apps/vitrine) — pages, articles, annonces, galerie, médias
// ============================================================================

enum VitrinePageStatus {
  DRAFT
  PUBLISHED
}

enum VitrineArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Canal de publication d'un VitrineArticle : « actualités » (brèves du
/// quotidien affichées sur /actualites) ou « blog » (articles de fond sur
/// /blog). Les deux canaux partagent la même structure (SEO, catégories,
/// commentaires, IA), ils sont juste filtrés sur le site public et
/// regroupés dans deux onglets côté admin.
enum VitrineArticleChannel {
  NEWS
  BLOG
}

enum MediaAssetKind {
  IMAGE
  DOCUMENT
  OTHER
}

/// Page vitrine — un enregistrement par (clubId, slug).
/// `sectionsJson` = tableau ordonné [{ id, type, props }] rendu par
/// `VitrinePageRenderer` côté Next.js. Permet une migration future vers
/// GrapeJS sans changer le schéma (même format JSON).
model VitrinePage {
  id             String            @id @default(uuid())
  clubId         String
  slug           String
  templateKey    String            @default("sksr-v1")
  status         VitrinePageStatus @default(PUBLISHED)
  seoTitle       String?
  seoDescription String?
  seoOgImageId   String?
  sectionsJson   Json
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  club       Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  seoOgImage MediaAsset?           @relation("VitrinePageOgImage", fields: [seoOgImageId], references: [id], onDelete: SetNull)
  revisions  VitrinePageRevision[]

  @@unique([clubId, slug])
  @@index([clubId, status])
}

/// Révision historique dune `VitrinePage` — permet undo/redo côté admin.
/// Plafonnée à ~50 rangées par page (nettoyage programmatique côté service).
model VitrinePageRevision {
  id             String   @id @default(uuid())
  pageId         String
  sectionsJson   Json
  seoTitle       String?
  seoDescription String?
  authorUserId   String?
  createdAt      DateTime @default(now())

  page VitrinePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
}

/// État de génération IA d'un article vitrine.
/// - NONE : article créé manuellement (pas de génération)
/// - PENDING : génération IA en cours en arrière-plan
/// - DONE : génération terminée avec succès
/// - FAILED : génération échouée (voir generationError)
enum VitrineArticleGenerationStatus {
  NONE
  PENDING
  DONE
  FAILED
}

/// Statut d'un commentaire sur un article vitrine après modération.
/// - PENDING : vient d'être soumis, modération IA en cours
/// - APPROVED : IA a jugé OK → visible sur la vitrine publique
/// - NEEDS_REVIEW : IA a flagué pour relecture humaine (admin doit trancher)
/// - REJECTED : IA ou admin a rejeté (non visible public)
/// - SPAM : spam détecté (non visible public + bloqué futur)
enum VitrineCommentStatus {
  PENDING
  APPROVED
  NEEDS_REVIEW
  REJECTED
  SPAM
}

/// Catégorie d'article vitrine (type WordPress). Un article peut avoir
/// plusieurs catégories via la table de jointure implicite Prisma.
model VitrineCategory {
  id          String   @id @default(uuid())
  clubId      String
  slug        String
  name        String
  description String?
  /// Couleur hex pour le badge visuel (#RRGGBB). Si null → couleur par défaut.
  color       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club     Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  articles VitrineArticle[] @relation("VitrineArticleCategories")

  @@unique([clubId, slug])
  @@index([clubId, sortOrder])
}

/// Commentaire sur un article vitrine (public, soumis par un visiteur).
/// Modéré automatiquement par IA avant affichage.
model VitrineComment {
  id               String               @id @default(uuid())
  articleId        String
  authorName       String
  authorEmail      String
  body             String
  ipAddress        String?
  userAgent        String?
  status           VitrineCommentStatus @default(PENDING)
  /// Score IA 0.0 (rejeté) → 1.0 (parfait). Null = pas encore modéré.
  aiScore          Float?
  /// Catégorie attribuée par l'IA (constructive, off-topic, offensive, spam, insulting, other).
  aiCategory       String?
  /// Raison lisible de la décision IA (affichée à l'admin).
  aiReason         String?
  /// Id user admin qui a review manuellement (si applicable).
  reviewedByUserId String?
  reviewedAt       DateTime?

  /// Réponse de l'admin (ou générée par IA, validée par admin avant publication).
  /// Null = pas de réponse publiée.
  adminReplyBody       String?
  /// Nom à afficher pour la réponse (ex. "Sensei Tanaka", "L'équipe SKSR", "Direction").
  adminReplyAuthorName String?
  adminReplyAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article VitrineArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, status, createdAt])
  @@index([status, createdAt])
}

/// Article vitrine — distinct du BlogPost (lui réservé aux membres connectés).
///
/// `bodyJson` = `{ format: 'html', html: '...' }` (WYSIWYG Tiptap) OU
/// `['para1', 'para2']` (ancien format paragraphes, rétrocompatible lecture).
model VitrineArticle {
  id           String               @id @default(uuid())
  clubId       String
  slug         String
  title        String
  excerpt      String?
  bodyJson     Json
  coverImageId String?
  status       VitrineArticleStatus @default(DRAFT)
  /// Canal : actualité courte (NEWS) ou article de fond (BLOG). Filtre
  /// les deux listes publiques /actualites et /blog, et groupe les deux
  /// onglets dans l'admin — création, SEO, catégories, commentaires,
  /// génération IA et tampon acquitté identiques quelle que soit la valeur.
  channel      VitrineArticleChannel @default(BLOG)
  publishedAt  DateTime?
  authorUserId String?
  /// Épinglé en tête de la liste de son canal (/actualites ou /blog).
  pinned       Boolean              @default(false)
  /// Ordre manuel (drag-and-drop admin). Plus petit = plus haut. Les
  /// articles épinglés sont triés entre eux par sortOrder avant les non
  /// épinglés (eux-mêmes triés par publishedAt desc).
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  // --- SEO ---
  seoTitle         String? // <title> balise, ≤ 60 chars recommandé
  seoDescription   String? // <meta name="description">, 150-160 chars
  seoKeywords      String[] @default([]) // LSI / mots-clés cibles
  seoH1            String? // H1 de l'article (si différent du titre)
  seoFaqJson       Json?   // [{question, answer}] pour schema.org FAQPage
  seoCanonicalUrl  String? // URL canonical si dupliquée ailleurs
  seoNoindex       Boolean @default(false)
  seoOgImageId     String? // Image Open Graph (partage sociaux). Si null → coverImageId.
  coverImageAlt    String? // alt de l'image de couverture

  // --- Génération IA en arrière-plan ---
  generationStatus   VitrineArticleGenerationStatus @default(NONE)
  generationProgress String?  // libellé courant (ex. "Génération du texte…", "Images 2/4")
  generationError    String?  // message d'erreur si FAILED
  generationWarnings String[] @default([]) // avertissements non-bloquants (ex. image gen failed)
  generationStartedAt DateTime?
  generationEndedAt   DateTime?

  club       Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  coverImage MediaAsset?       @relation("VitrineArticleCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  seoOgImage MediaAsset?       @relation("VitrineArticleOgImage", fields: [seoOgImageId], references: [id], onDelete: SetNull)
  categories VitrineCategory[] @relation("VitrineArticleCategories")
  comments   VitrineComment[]

  @@unique([clubId, slug])
  @@index([clubId, status, publishedAt])
  @@index([clubId, channel, status, publishedAt])
  @@index([clubId, generationStatus])
}

/// Annonce courte affichée sur la vitrine (≠ ClubAnnouncement membre).
model VitrineAnnouncement {
  id          String    @id @default(uuid())
  clubId      String
  title       String
  body        String
  pinned      Boolean   @default(false)
  /// Ordre manuel (drag-and-drop admin). Plus petit = plus haut. Les
  /// annonces épinglées sont triées entre elles par sortOrder avant les non
  /// épinglées.
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, publishedAt])
}

/// Photo de galerie publique — pointée vers un MediaAsset.
model VitrineGalleryPhoto {
  id           String   @id @default(uuid())
  clubId       String
  mediaAssetId String
  caption      String?
  category     String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  club       Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation("VitrineGalleryPhotoAsset", fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([clubId, category, sortOrder])
}

/// Actif média générique (image, document) — scope par club, propriétaire
/// polymorphe (`ownerKind` + `ownerId`). Remplace progressivement
/// `ClubEventAttachment` en Phase 2.
model MediaAsset {
  id               String         @id @default(uuid())
  clubId           String
  kind             MediaAssetKind @default(IMAGE)
  ownerKind        String?
  ownerId          String?
  fileName         String
  mimeType         String
  sizeBytes        Int
  storagePath      String
  publicUrl        String
  widthPx          Int?
  heightPx         Int?
  uploadedByUserId String?
  createdAt        DateTime       @default(now())

  club           Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  galleryPhotos  VitrineGalleryPhoto[] @relation("VitrineGalleryPhotoAsset")
  articleCovers  VitrineArticle[]      @relation("VitrineArticleCover")
  articleOgImages VitrineArticle[]     @relation("VitrineArticleOgImage")
  ogPages        VitrinePage[]         @relation("VitrinePageOgImage")
  projectPosters ClubProject[]         @relation("ProjectPoster")
  projectCovers  ClubProject[]         @relation("ProjectCover")
  projectLiveItems ProjectLiveItem[]   @relation("ProjectLiveItemMedia")

  @@index([clubId, ownerKind, ownerId])
}
// ============================================================================
// Module PROJETS  (v1 — cf. plan glowing-bubbling-llama.md)
// ----------------------------------------------------------------------------
// ClubProject + sections built-in (Bénévolat/Admin/Com/Live + Accounting r-o),
// phases LIVE multiples, contributeurs polymorphes, items (photos/vidéos)
// modérés IA puis humain, comptes-rendus IA, listes de diffusion RGPD.
// ============================================================================

enum ProjectStatus {
  PLANNED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ProjectLivePhaseState {
  UPCOMING
  LIVE
  CLOSED
}

enum ProjectSectionKind {
  VOLUNTEERS
  ADMIN
  COMMUNICATION
  LIVE
  ACCOUNTING
  CUSTOM
}

enum ProjectContributorRole {
  CONTRIBUTOR
}

enum ProjectLiveItemKind {
  PHOTO
  VIDEO
  /// Soumission texte libre (témoignage, caption, anecdote). `textContent`
  /// est renseigné, `mediaAssetId` reste null. Utilisé pour enrichir les
  /// comptes-rendus sans nécessiter une photo ou une vidéo.
  TEXT
}

enum ProjectLiveItemAiDecision {
  PENDING
  APPROVED
  REJECTED
  ERROR
}

enum ProjectLiveItemHumanDecision {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectLiveItemPublication {
  NONE
  VITRINE_NEWS
  VITRINE_BLOG
  MEMBER_ANNOUNCEMENT
}

enum ProjectReportTemplate {
  COMPETITIF
  FESTIF
  BILAN
  /// Génération avec prompt personnalisé fourni par l'admin (ex. « fais un
  /// compte-rendu des performances de nos athlètes »). Le champ `customPrompt`
  /// de `ProjectReport` est alors renseigné et remplace le preset de ton.
  CUSTOM
}

enum ProjectReportStatus {
  DRAFT
  PUBLISHED
}

enum DistributionMailStatus {
  DRAFT
  SENT
  FAILED
  UNSUBSCRIBED
}

/// Événement / Projet long-terme (au-delà d'un ClubEvent simple).
/// Créé avec 4 sections built-in (VOLUNTEERS, ADMIN, COMMUNICATION, LIVE),
/// et une 5e section ACCOUNTING en lecture seule si le module compta est
/// actif. Rename + reorder des sections possibles dès v1.
model ClubProject {
  id            String        @id @default(uuid())
  clubId        String
  slug          String
  title         String
  summary       String?
  description   String?
  status        ProjectStatus @default(PLANNED)
  startsAt      DateTime?
  endsAt        DateTime?
  posterAssetId String?
  coverImageId  String?
  budgetPlannedCents Int?

  /// Quotas par contributeur par phase LIVE — configurables par projet.
  maxPhotosPerContributorPerPhase Int     @default(10)
  maxVideosPerContributorPerPhase Int     @default(3)
  maxTextsPerContributorPerPhase  Int     @default(20)
  /// Toggle admin : afficher la liste des contributeurs en bas d'un
  /// compte-rendu publié (respect des contributeurs anonymes).
  showContributorCredits          Boolean @default(true)

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  club          Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  posterAsset   MediaAsset?           @relation("ProjectPoster", fields: [posterAssetId], references: [id], onDelete: SetNull)
  coverImage    MediaAsset?           @relation("ProjectCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  sections      ProjectSection[]
  livePhases    ProjectLivePhase[]
  contributors  ProjectContributor[]
  liveItems     ProjectLiveItem[]
  reports       ProjectReport[]
  distributions ProjectDistribution[]
  events        ClubEvent[]
  accountingEntries  AccountingEntry[]
  messageCampaigns   MessageCampaign[]
  agentConversations AgentConversation[]

  @@unique([clubId, slug])
  @@index([clubId, status])
}

/// Section structurée d'un projet (wiki rich-text + documents joints via
/// MediaAsset.ownerKind='PROJECT_SECTION'). V1 : 4 kinds built-in + ACCOUNTING
/// lecture seule conditionnelle. Renommable, réordonnable.
model ProjectSection {
  id        String             @id @default(uuid())
  projectId String
  kind      ProjectSectionKind
  label     String
  sortOrder Int                @default(0)
  /// Wiki Tiptap JSON — contenu longue forme édité depuis l'admin.
  bodyJson  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project ClubProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}

/// Phase LIVE d'un projet — un projet peut avoir N phases (ex. stage 3 jours).
/// Chaque phase a son cycle `UPCOMING → LIVE → CLOSED` et ses propres quotas
/// contributeurs (les quotas sont comptés sur `phaseId` + `contributorId`).
model ProjectLivePhase {
  id        String                @id @default(uuid())
  projectId String
  label     String
  startsAt  DateTime
  endsAt    DateTime
  state     ProjectLivePhaseState @default(UPCOMING)
  openedAt  DateTime?
  closedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   ClubProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  liveItems ProjectLiveItem[]

  @@index([projectId, startsAt])
}

/// Contributeur d'un projet — polymorphe Member OU Contact (exactement un).
/// Portée par projet, rôle unique `CONTRIBUTOR` en v1, révocation manuelle
/// via `revokedAt` + raison, désactivation auto via hook Member.status.
model ProjectContributor {
  id            String                 @id @default(uuid())
  projectId     String
  memberId      String?
  contactId     String?
  role          ProjectContributorRole @default(CONTRIBUTOR)
  addedByUserId String
  addedAt       DateTime               @default(now())
  revokedAt     DateTime?
  revokedReason String?

  project   ClubProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member    Member?            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contact   Contact?           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  liveItems ProjectLiveItem[]

  @@index([projectId, revokedAt])
  @@index([memberId])
  @@index([contactId])
}

/// Item uploadé pendant la phase LIVE (photo ou vidéo). Pipeline :
///   PENDING (IA) → APPROVED/REJECTED/ERROR (aiDecision)
///   PENDING (humain) → APPROVED/REJECTED (humanDecision, override possible)
///   publishedTo : NONE par défaut, VITRINE_NEWS / VITRINE_BLOG /
///     MEMBER_ANNOUNCEMENT selon ce que l'admin publie.
model ProjectLiveItem {
  id             String                       @id @default(uuid())
  projectId      String
  phaseId        String?
  contributorId  String
  kind           ProjectLiveItemKind
  /// Nullable pour permettre les items de kind=TEXT (le textContent est
  /// alors renseigné à la place). Requis pour PHOTO et VIDEO — validation
  /// applicative dans `project-live-item.service.ts::submit()`.
  mediaAssetId   String?
  /// Contenu texte brut (max 4000 chars), pour kind=TEXT uniquement.
  /// Stocké tel quel, la modération IA texte peut le parcourir ensuite.
  textContent    String?
  submittedAt    DateTime                     @default(now())
  /// False si l'upload a eu lieu après ProjectLivePhase.state=CLOSED.
  /// L'UI affiche alors un badge « ajout tardif ».
  submittedDuringLive Boolean                 @default(true)

  aiDecision     ProjectLiveItemAiDecision    @default(PENDING)
  aiReason       String?
  aiScore        Float?
  aiCheckedAt    DateTime?

  humanDecision  ProjectLiveItemHumanDecision @default(PENDING)
  humanDecidedBy String?
  humanDecidedAt DateTime?

  publishedTo    ProjectLiveItemPublication   @default(NONE)
  publishedRefId String?

  project     ClubProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       ProjectLivePhase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  contributor ProjectContributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  mediaAsset  MediaAsset?        @relation("ProjectLiveItemMedia", fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([projectId, submittedAt])
  @@index([projectId, aiDecision, humanDecision])
  @@index([contributorId, phaseId, kind])
}

/// Compte-rendu IA d'un projet. 3 templates (COMPETITIF / FESTIF / BILAN),
/// draft édité en Tiptap par l'admin puis publié comme VitrineArticle.
/// Stocke les contributeurs crédités pour l'attribution en bas d'article.
model ProjectReport {
  id             String                     @id @default(uuid())
  projectId      String
  template       ProjectReportTemplate
  status         ProjectReportStatus        @default(DRAFT)
  title          String
  /// Prompt libre saisi par l'admin. Renseigné uniquement pour
  /// template=CUSTOM, null pour les 3 presets prédéfinis. Max 2000 chars.
  customPrompt   String?
  bodyJson       Json
  /// IDs des ProjectLiveItem effectivement utilisés par le générateur IA.
  sourceLiveItemIds            String[]     @default([])
  /// IDs Member cités / crédités (union Member + Contact via deux colonnes
  /// parallèles — pattern FamilyMember).
  sourceContributorMemberIds   String[]     @default([])
  sourceContributorContactIds  String[]     @default([])
  publishedTo    ProjectLiveItemPublication @default(NONE)
  publishedRefId String?
  generatedByAgentConversationId String?
  createdByUserId String
  createdAt       DateTime @default(now())
  publishedAt     DateTime?
  updatedAt       DateTime @updatedAt

  project ClubProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

/// Liste de diffusion club-level (réutilisable entre projets). Ex. « Mairie »,
/// « Partenaires », « Presse locale ». V2 — anticipé en v1 pour le schéma.
model DistributionList {
  id          String @id @default(uuid())
  clubId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club          Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  contacts      DistributionContact[]
  distributions ProjectDistribution[]

  @@unique([clubId, name])
}

/// Contact d'une liste de diffusion — RGPD : consentement daté + source
/// obligatoires, unsubscribe trace via `consentRevokedAt`.
model DistributionContact {
  id               String    @id @default(uuid())
  listId           String
  firstName        String?
  lastName         String?
  organization     String?
  email            String
  phone            String?
  consentGivenAt   DateTime
  consentSource    String
  consentRevokedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  list  DistributionList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  sends DistributionSend[]

  @@unique([listId, email])
  @@index([email])
}

/// Envoi d'un mail projet → liste de diffusion (v2). Draft IA éditable puis
/// envoi via ClubSendingDomain + SPF/DKIM. Un `DistributionSend` par destinataire
/// avec token unsubscribe unique.
model ProjectDistribution {
  id                    String    @id @default(uuid())
  projectId             String
  listId                String
  subject               String
  bodyHtml              String
  bodyText              String?
  attachedMediaAssetIds String[]  @default([])
  aiDraftedAt           DateTime?
  createdByUserId       String
  createdAt             DateTime  @default(now())
  sentAt                DateTime?

  project ClubProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  list    DistributionList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  sends   DistributionSend[]

  @@index([projectId])
  @@index([listId])
}

/// Log immuable d'envoi pour audit RGPD — un send par (distribution, contact).
/// Seule la colonne `openedAt` est updatable (pixel tracking optionnel).
model DistributionSend {
  id               String                 @id @default(uuid())
  distributionId   String
  contactId        String
  /// Copie figée de l'email au moment de l'envoi (audit RGPD, évite de
  /// perdre la trace si le contact est modifié/supprimé après).
  email            String
  status           DistributionMailStatus @default(DRAFT)
  /// Token unique pour le lien unsubscribe dans le mail.
  unsubscribeToken String                 @unique
  sentAt           DateTime?
  deliveredAt      DateTime?
  openedAt         DateTime?
  errorMessage     String?

  distribution ProjectDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  contact      DistributionContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([distributionId, status])
}
