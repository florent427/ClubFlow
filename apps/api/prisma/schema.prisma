  updatedAt    DateTime                @updatedAt

  courseSlot CourseSlot @relation(fields: [courseSlotId], references: [id], onDelete: Cascade)
  member     Member     @relation("CourseSlotBookingMember", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([courseSlotId, memberId])
  @@index([courseSlotId])
  @@index([memberId])
