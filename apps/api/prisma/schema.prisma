// --- Adhésion : saisons, groupes persistés, formules, lignes de facture ---

model ClubSeason {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  startsOn  DateTime @db.Date
  endsOn    DateTime @db.Date
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club            Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  membershipCarts MembershipCart[]

  @@index([clubId])
}

model MemberDynamicGroup {
  id             String   @id @default(uuid())
  clubId         String
  memberId       String
  dynamicGroupId String
  createdAt      DateTime @default(now())

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  dynamicGroup DynamicGroup @relation(fields: [dynamicGroupId], references: [id], onDelete: Cascade)

  @@unique([memberId, dynamicGroupId])
  @@index([clubId, memberId])
}

model MembershipProduct {
  id                      String    @id @default(uuid())
  clubId                  String
  label                   String
  annualAmountCents       Int
  monthlyAmountCents      Int
  minAge                  Int?
  maxAge                  Int?
  allowProrata            Boolean   @default(true)
  allowFamily             Boolean   @default(true)
  allowPublicAid          Boolean   @default(true)
  allowExceptional        Boolean   @default(true)
  exceptionalCapPercentBp Int?
  archivedAt              DateTime?
  /// Code discipline libre (ex. "karate", "judo", "yoga") utilisé pour la
  /// ventilation analytique comptable. Convention slug minuscule.
  disciplineCode          String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  club         Club                          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gradeFilters MembershipProductGradeLevel[]
  invoiceLines InvoiceLine[]
  cartItems    MembershipCartItem[]

  @@index([clubId])
}

model MembershipProductGradeLevel {
  membershipProductId String
  gradeLevelId        String

  membershipProduct MembershipProduct @relation(fields: [membershipProductId], references: [id], onDelete: Cascade)
  gradeLevel        GradeLevel        @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@id([membershipProductId, gradeLevelId])
}

enum MembershipOneTimeFeeKind {
  /// Licence fédérale. Skipée automatiquement si le membre coche « j'ai déjà une licence ».
  LICENSE
  /// Frais obligatoire (cotisation club, kit équipement...). Toujours ajouté.
  MANDATORY
  /// Frais optionnel. Ajouté uniquement si sélectionné manuellement.
  OPTIONAL
}

model MembershipOneTimeFee {
  id          String                   @id @default(uuid())
  clubId      String
  label       String
  amountCents Int
  /// Classification fonctionnelle ; pilote l'auto-ajout au panier d'adhésion.
  kind        MembershipOneTimeFeeKind @default(OPTIONAL)
  /// Ajouté automatiquement à chaque item du panier d'adhésion créé.
  autoApply   Boolean                  @default(false)
  archivedAt  DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoiceLines InvoiceLine[]

  @@index([clubId])
}

enum InvoiceLineKind {
  MEMBERSHIP_SUBSCRIPTION
  MEMBERSHIP_ONE_TIME
}

enum SubscriptionBillingRhythm {
  ANNUAL
  MONTHLY
}

enum InvoiceLineAdjustmentType {
  PRORATA_SEASON
  FAMILY
  PUBLIC_AID
  EXCEPTIONAL
}

model InvoiceLine {
  id                        String                     @id @default(uuid())
  invoiceId                 String
  kind                      InvoiceLineKind            @default(MEMBERSHIP_SUBSCRIPTION)
  memberId                  String
  membershipProductId       String?
  membershipOneTimeFeeId    String?
  subscriptionBillingRhythm SubscriptionBillingRhythm?
  dynamicGroupId            String?
  baseAmountCents           Int
  sortOrder                 Int                        @default(0)

  invoice              Invoice                 @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  member               Member                  @relation(fields: [memberId], references: [id], onDelete: Restrict)
  membershipProduct    MembershipProduct?      @relation(fields: [membershipProductId], references: [id], onDelete: SetNull)
  membershipOneTimeFee MembershipOneTimeFee?   @relation(fields: [membershipOneTimeFeeId], references: [id], onDelete: SetNull)
  dynamicGroup         DynamicGroup?           @relation(fields: [dynamicGroupId], references: [id], onDelete: SetNull)
  adjustments          InvoiceLineAdjustment[]

  @@index([invoiceId])
  @@index([memberId])
}

model InvoiceLineAdjustment {
  id               String                    @id @default(uuid())
  lineId           String
  stepOrder        Int
  type             InvoiceLineAdjustmentType
  amountCents      Int
  percentAppliedBp Int?
  metadataJson     String?
  reason           String?
  createdByUserId  String?

  line InvoiceLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@index([lineId])
}

// --- Phase E : Paiement (factures, encaissements, tarification, Stripe) ---

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

enum ClubPaymentMethod {
  STRIPE_CARD
  MANUAL_CASH
  MANUAL_CHECK
  MANUAL_TRANSFER
}

/// Type d'un compte financier club. Permet de regrouper banques, caisses,
/// comptes de transit (Stripe, HelloAsso, Lydia) sous un même modèle, tout
/// en gardant la sémantique métier explicite pour l'UI et le routage.
///
/// Mapping conventionnel vers le PCG :
/// - BANK             → 512xxx (Crédit Agricole, BRED, etc.)
/// - CASH             → 53xxxx (caisse dojo, caisse buvette)
/// - STRIPE_TRANSIT   → 512xxx (compte Stripe distinct de la banque réelle)
/// - OTHER_TRANSIT    → 511xxx ou 512xxx (HelloAsso, Lydia, PayPal, …)
enum ClubFinancialAccountKind {
  BANK
  CASH
  STRIPE_TRANSIT
  OTHER_TRANSIT
}

/// Compte financier réel d'un club (banque, caisse, transit Stripe…).
/// Lié à un AccountingAccount du plan comptable (FK forte). Permet :
/// - Suivi des soldes par compte
/// - Routage automatique des paiements selon `ClubPaymentMethod`
/// - Sélection "Encaissé sur" lors d'une saisie d'écriture
///
/// Toujours créé via `ClubFinancialAccountsService` qui valide la
/// cohérence kind ↔ code PCG (BANK doit pointer sur 51x, CASH sur 53x).
model ClubFinancialAccount {
  id                  String                   @id @default(uuid())
  clubId              String
  kind                ClubFinancialAccountKind
  /// Libellé lisible utilisateur (ex : "Crédit Agricole pro").
  label               String
  /// FK forte vers AccountingAccount = source de vérité pour code/label
  /// PCG. On évite le snapshot pour ne pas dériver si l'admin renomme.
  accountingAccountId String
  /// Optionnels : utiles pour rapprochement bancaire v2 et identification.
  iban                String?
  bic                 String?
  /// `acct_xxx` Stripe pour kind=STRIPE_TRANSIT. Informatif en v1
  /// (pas de discriminator multi-Stripe).
  stripeAccountId     String?
  /// 1 default max par (clubId, kind) — appliqué côté service.
  isDefault           Boolean                  @default(false)
  isActive            Boolean                  @default(true)
  sortOrder           Int                      @default(0)
  /// Notes libres (ex : "Caisse événementielle Coupe SKSR 2026").
  notes               String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  club              Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  accountingAccount AccountingAccount @relation(fields: [accountingAccountId], references: [id], onDelete: Restrict)

  paymentRoutes ClubPaymentRoute[]
  entries       AccountingEntry[]
  payments      Payment[]

  /// Empêche 2 comptes financiers liés au même compte PCG (un compte PCG
  /// ne peut représenter qu'un compte réel).
  @@unique([clubId, accountingAccountId])
  @@index([clubId, kind, isActive])
}

/// Routage `ClubPaymentMethod → ClubFinancialAccount`. Permet à l'admin
/// de configurer "tous les paiements Stripe atterrissent sur le compte
/// transit Stripe", "tous les espèces vont à la caisse principale", etc.
///
/// 1 route par (clubId, method) en v1 (pas de discriminator multi-Stripe).
model ClubPaymentRoute {
  id                 String            @id @default(uuid())
  clubId             String
  method             ClubPaymentMethod
  financialAccountId String
  isDefault          Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  club             Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  financialAccount ClubFinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

  @@unique([clubId, method])
  @@index([clubId, method])
}

enum PricingAdjustmentType {
  NONE
  PERCENT_BP
  FIXED_CENTS
}

/// Type de pattern de règle de remise. Chaque pattern a un schéma de
/// `configJson` distinct, validé par Zod côté service.
///
/// - FAMILY_PROGRESSIVE : grille de remises progressives selon le rang du
///   membre dans le foyer (2e, 3e, 4e+). Appliqué uniquement aux
///   cotisations (pas aux frais de licence/dossier).
/// - PRODUCT_BUNDLE : si plusieurs produits sont présents ensemble dans
///   le cart, remise sur l'un d'eux (ex Karaté + Cross Training = -20€
///   sur Cross Training).
/// - AGE_RANGE_DISCOUNT : remise sur les membres dans une tranche d'âge
///   (ex moins de 12 ans = -15%).
/// - NEW_MEMBER_DISCOUNT : remise sur les nouveaux adhérents (jamais
///   inscrits avant cette saison).
/// - LOYALTY_DISCOUNT : remise fidélité (X années consécutives).
enum MembershipPricingRulePattern {
  FAMILY_PROGRESSIVE
  PRODUCT_BUNDLE
  AGE_RANGE_DISCOUNT
  NEW_MEMBER_DISCOUNT
  LOYALTY_DISCOUNT
}

/// Règle de remise configurable par l'admin. La structure de `configJson`
/// dépend de `pattern` ; chaque pattern a son schéma Zod côté service
/// avec validation stricte à la création/update + au runtime
/// (fallback safe si configJson devient incompatible suite à un
/// changement de schéma — la règle est désactivée et loggée plutôt que
/// crasher la facturation).
///
/// Exemples :
///
/// FAMILY_PROGRESSIVE :
/// ```
/// {
///   "tiers": [
///     { "rank": 2, "type": "PERCENT_BP", "value": -1000 },
///     { "rank": 3, "type": "PERCENT_BP", "value": -2000 },
///     { "rank": 4, "type": "PERCENT_BP", "value": -3000 }
///   ],
///   "appliesTo": ["SUBSCRIPTION"],
///   "sortBy": "AMOUNT_DESC"
/// }
/// ```
///
/// PRODUCT_BUNDLE :
/// ```
/// {
///   "requiredProductIds": ["uuid-karate", "uuid-crosstraining"],
///   "discountAppliesToProductId": "uuid-crosstraining",
///   "discountType": "FIXED_CENTS",
///   "discountValue": -2000
/// }
/// ```
model MembershipPricingRule {
  id          String                       @id @default(uuid())
  clubId      String
  pattern     MembershipPricingRulePattern
  /// Libellé lisible (ex "Remise famille progressive"). Affiché dans
  /// l'UI Settings et dans le détail facture.
  label       String
  isActive    Boolean                      @default(true)
  /// Ordre d'évaluation. Les règles avec priority bas sont évaluées
  /// d'abord. Permet de chaîner plusieurs remises de manière
  /// déterministe.
  priority    Int                          @default(0)
  /// Configuration spécifique au pattern. Schéma validé par Zod.
  configJson  Json
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, isActive, priority])
  @@index([clubId, pattern])
}

model ClubPricingRule {
  id              String                @id @default(uuid())
  clubId          String
  method          ClubPaymentMethod
  adjustmentType  PricingAdjustmentType @default(NONE)
  adjustmentValue Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, method])
  @@index([clubId])
}

model Invoice {
  id                    String             @id @default(uuid())
  clubId                String
  familyId              String?
  householdGroupId      String?
  clubSeasonId          String?
  label                 String
  baseAmountCents       Int
  amountCents           Int
  status                InvoiceStatus      @default(OPEN)
  lockedPaymentMethod   ClubPaymentMethod?
  /// Nombre de versements demandés par le payeur. 1 = paiement complet,
  /// 3 = échelonnement en 3 versements (option exposée pour les
  /// cotisations annuelles uniquement). Le club peut suivre l'échéancier
  /// dans son back-office (paiements partiels reçus).
  installmentsCount     Int                @default(1)
  dueAt                 DateTime?
  stripePaymentIntentId String?            @unique
  /// Dernière date d'envoi d'un e-mail de relance pour cette facture.
  lastRemindedAt        DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  /// true si ce document est un AVOIR (contre-facture) — montant cents reste positif côté modèle,
  /// inversé à l'affichage et en comptabilité.
  isCreditNote     Boolean @default(false)
  /// Pour un avoir : id de la facture source (qui est remboursée/annulée partiellement).
  parentInvoiceId  String?
  /// Motif textuel affiché sur l'avoir (« erreur de saisie », « remboursement cotisation »…)
  creditNoteReason String?

  club           Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  family         Family?         @relation(fields: [familyId], references: [id], onDelete: SetNull)
  householdGroup HouseholdGroup? @relation(fields: [householdGroupId], references: [id], onDelete: SetNull)
  clubSeason     ClubSeason?     @relation(fields: [clubSeasonId], references: [id], onDelete: SetNull)
  lines          InvoiceLine[]
  payments       Payment[]
  membershipCart MembershipCart?

  parentInvoice Invoice?  @relation("InvoiceCreditNotes", fields: [parentInvoiceId], references: [id], onDelete: SetNull)
  creditNotes   Invoice[] @relation("InvoiceCreditNotes")

  @@index([clubId, status])
  @@index([clubId, householdGroupId, status])
  @@index([clubSeasonId])
  @@index([parentInvoiceId])
}

model Payment {
  id                 String            @id @default(uuid())
  clubId             String
  invoiceId          String
  amountCents        Int
  method             ClubPaymentMethod
  externalRef        String?
  /// Payeur réel (portail / traçabilité). Null = encaissement club catalogué sans fiche membre payeur.
  paidByMemberId     String?
  /// Payeur contact (sans fiche `Member`). Au plus un de `paidByMemberId` / `paidByContactId` (appli).
  paidByContactId    String?
  /// Compte financier où l'argent est tombé (snapshot au moment du paiement).
  /// Null = legacy ou paiement créé avant configuration multi-comptes.
  /// Résolu via `ClubFinancialAccountsService.resolveForPayment(clubId, method)`.
  financialAccountId String?
  createdAt          DateTime          @default(now())

  club                    Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoice                 Invoice                  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  paidByMember            Member?                  @relation("PaymentPaidByMember", fields: [paidByMemberId], references: [id], onDelete: SetNull)
  paidByContact           Contact?                 @relation("PaymentPaidByContact", fields: [paidByContactId], references: [id], onDelete: SetNull)
  financialAccount        ClubFinancialAccount?    @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  accountingEntries       AccountingEntry[]
  grantInstallments       GrantInstallment[]
  sponsorshipInstallments SponsorshipInstallment[]

  @@index([clubId, createdAt])
  @@index([invoiceId])
  @@index([paidByMemberId])
  @@index([paidByContactId])
  @@index([clubId, financialAccountId])
}

model StripeWebhookEvent {
  id          String   @id
  processedAt DateTime @default(now())
}

// --- Phase F : Communication (campagnes, audience = groupes dynamiques) ---

enum CommunicationChannel {
  EMAIL
  TELEGRAM
  PUSH
  /// Diffusion via la messagerie interne : la campagne poste un message
  /// dans tous les salons cibles (typiquement les ChatRoom marqués
  /// `isBroadcastChannel = true`).
  MESSAGING
}

enum MessageCampaignStatus {
  DRAFT
  SENT
}

model MessageCampaign {
