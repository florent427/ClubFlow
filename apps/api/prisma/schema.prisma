generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Club {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   ClubMembership[]
  modules       ClubModule[]
  gradeLevels     GradeLevel[]
  roleDefinitions ClubRoleDefinition[]
  members         Member[]
  dynamicGroups DynamicGroup[]
  families      Family[]
  householdGroups HouseholdGroup[]
  venues        Venue[]
  courseSlots   CourseSlot[]

  pricingRules        ClubPricingRule[]
  invoices            Invoice[]
  payments            Payment[]
  messageCampaigns    MessageCampaign[]
  accountingEntries   AccountingEntry[]
  grantApplications   GrantApplication[]
  sponsorshipDeals    SponsorshipDeal[]
  memberFieldCatalogSettings    ClubMemberFieldCatalogSetting[]
  memberCustomFieldDefinitions  MemberCustomFieldDefinition[]
  clubSeasons                   ClubSeason[]
  membershipProducts            MembershipProduct[]
  membershipOneTimeFees         MembershipOneTimeFee[]
  sendingDomains                ClubSendingDomain[]
  emailSuppressions             EmailSuppression[]
  contacts                      Contact[]
  chatRooms                     ChatRoom[]
  /// À partir du n-ième bulletin d’adhésion (OPEN/PAID) pour le foyer sur la saison — null = désactivé
  membershipFamilyDiscountFromNth Int?
  membershipFamilyAdjustmentType   PricingAdjustmentType @default(NONE)
  membershipFamilyAdjustmentValue  Int                   @default(0)
}

enum MembershipRole {
  CLUB_ADMIN
  BOARD
  COACH
  TREASURER
  SECRETARY
  STAFF
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?
  emailVerifiedAt DateTime?
  displayName     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships             ClubMembership[]
  tokens                  RefreshToken[]
  members                 Member[]
  contacts                Contact[]
  userIdentities          UserIdentity[]
  emailVerificationTokens EmailVerificationToken[]
}

enum OAuthProvider {
  GOOGLE
  FACEBOOK
  LINKEDIN
}

/// Prospect / contact portail — distinct du membre adhérent (`Member`)
model Contact {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club                 Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Liens `FamilyMember` où ce contact est désigné payeur (`linkRole = PAYER`).
  familyMemberPayerLinks FamilyMember[] @relation("FamilyMemberPayerContact")
  paymentsAsPaidBy       Payment[]      @relation("PaymentPaidByContact")

  @@unique([userId, clubId])
}

model UserIdentity {
  id              String        @id @default(uuid())
  userId          String
  provider        OAuthProvider
  providerSubject String
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClubMembership {
  id        String         @id @default(uuid())
  userId    String
  clubId    String
  role      MembershipRole @default(STAFF)
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

model ModuleDefinition {
  code        String   @id
  label       String
  isRequired  Boolean  @default(false)
  description String?
  clubModules ClubModule[]
}

model ClubModule {
  id         String    @id @default(uuid())
  clubId     String
  moduleCode String
  enabled    Boolean   @default(false)
  enabledAt  DateTime?
  disabledAt DateTime?

  club   Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  module ModuleDefinition @relation(fields: [moduleCode], references: [code], onDelete: Restrict)

  @@unique([clubId, moduleCode])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Module Membres (référentiel adhérents + grades + groupes dynamiques) ---

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum MemberClubRole {
  STUDENT
  COACH
  BOARD
}

enum MemberCivility {
  MR
  MME
}

/// Champs « catalogue » (colonnes Member) configurables sur la fiche admin
enum MemberCatalogFieldKey {
  PHONE
  ADDRESS_LINE
  POSTAL_CODE
  CITY
  BIRTH_DATE
  PHOTO_URL
  MEDICAL_CERT_EXPIRES_AT
  GRADE_LEVEL
}

enum MemberCustomFieldType {
  TEXT
  TEXT_LONG
  NUMBER
  DATE
  BOOLEAN
  SELECT
}

model ClubMemberFieldCatalogSetting {
  id         String                @id @default(uuid())
  clubId     String
  fieldKey   MemberCatalogFieldKey
  showOnForm Boolean               @default(true)
  required   Boolean               @default(false)
  sortOrder  Int                   @default(0)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, fieldKey])
  @@index([clubId])
}

model MemberCustomFieldDefinition {
  id              String                 @id @default(uuid())
  clubId          String
  code            String
  label           String
  type            MemberCustomFieldType
  required        Boolean                @default(false)
  sortOrder       Int                    @default(0)
  visibleToMember Boolean                @default(false)
  optionsJson     String?
  archivedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  club   Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  values MemberCustomFieldValue[]

  @@unique([clubId, code])
  @@index([clubId])
}

model MemberCustomFieldValue {
  id           String   @id @default(uuid())
  memberId     String
  definitionId String
  valueText    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  member     Member                      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  definition MemberCustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([memberId, definitionId])
  @@index([memberId])
  @@index([definitionId])
}

model GradeLevel {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club                  Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members               Member[]
  dynamicGroupGradeLevels DynamicGroupGradeLevel[]
  membershipProductGradeLevels MembershipProductGradeLevel[]

  @@index([clubId])
}

model Member {
  id                     String        @id @default(uuid())
  clubId                 String
  userId                 String?
  firstName              String
  lastName               String
  /// Pseudo messagerie ; unique par club ; [a-z0-9_]
  pseudo                 String   @db.VarChar(64)
  civility               MemberCivility
  email                  String
  phone                  String?
  addressLine            String?
  postalCode             String?
  city                   String?
  birthDate              DateTime?
  photoUrl               String?
  medicalCertExpiresAt   DateTime?
  status                 MemberStatus  @default(ACTIVE)
  gradeLevelId           String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  club             Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user             User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  gradeLevel       GradeLevel?             @relation(fields: [gradeLevelId], references: [id], onDelete: SetNull)
  roleAssignments         MemberRoleAssignment[]
  customRoleAssignments   MemberCustomRoleAssignment[]
  familyMembers           FamilyMember[]
  courseSlotsAsCoach CourseSlot[] @relation("CourseSlotCoach")
  messageCampaignRecipients MessageCampaignRecipient[]
  customFieldValues          MemberCustomFieldValue[]
  dynamicGroupAssignments    MemberDynamicGroup[]
  invoiceLines               InvoiceLine[]
  paymentsAsPaidBy           Payment[] @relation("PaymentPaidByMember")
  telegramChatId             String?   @map("telegram_chat_id")
  telegramLinkedAt           DateTime? @map("telegram_linked_at")
  telegramLinkTokens         TelegramLinkToken[]
  chatRoomMemberships        ChatRoomMember[]
  chatMessagesSent           ChatMessage[]    @relation("ChatMessageSender")
  chatRoomsCreated           ChatRoom[]       @relation("MemberChatRoomsCreated")

  @@unique([clubId, userId])
  @@unique([clubId, pseudo])
  @@index([clubId])
  @@index([clubId, status])
}

enum ChatRoomKind {
  DIRECT
  GROUP
  COMMUNITY
}

enum ChatRoomMemberRole {
  MEMBER
  ADMIN
}

model ChatRoom {
  id                 String         @id @default(uuid())
  clubId             String
  kind               ChatRoomKind
  name               String?
  directPairKey      String?        @unique
  createdByMemberId  String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  club    Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator Member?          @relation("MemberChatRoomsCreated", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  members ChatRoomMember[]
  messages ChatMessage[]

  @@index([clubId, kind])
}

model ChatRoomMember {
  id        String             @id @default(uuid())
  roomId    String
  memberId  String
  role      ChatRoomMemberRole @default(MEMBER)
  joinedAt  DateTime           @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  member Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([roomId, memberId])
  @@index([memberId])
}

model ChatMessage {
  id             String    @id @default(uuid())
  roomId         String
  senderMemberId String
  body           String    @db.Text
  createdAt      DateTime  @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender Member   @relation("ChatMessageSender", fields: [senderMemberId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

/// Jeton ponctuel pour `t.me/Bot?start=TOKEN` — lie le chat Telegram au membre.
model TelegramLinkToken {
  id         String    @id @default(uuid())
  clubId     String
  memberId   String
  token      String    @unique @db.VarChar(64)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([token])
}

model MemberRoleAssignment {
  id        String         @id @default(uuid())
  memberId  String
  role      MemberClubRole
  createdAt DateTime       @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, role])
}

/// Rôle « libellé » défini par le club (ex. bénévole, compétiteur). Les rôles
/// système STUDENT / COACH / BOARD restent sur MemberRoleAssignment (enum).
model ClubRoleDefinition {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club         Club                       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  assignments  MemberCustomRoleAssignment[]

  @@index([clubId])
}

model MemberCustomRoleAssignment {
  id               String   @id @default(uuid())
  memberId         String
  roleDefinitionId String
  createdAt        DateTime @default(now())

  member         Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  roleDefinition ClubRoleDefinition @relation(fields: [roleDefinitionId], references: [id], onDelete: Restrict)

  @@unique([memberId, roleDefinitionId])
  @@index([roleDefinitionId])
}

model DynamicGroup {
  id        String   @id @default(uuid())
  clubId    String
  name      String
  minAge    Int?
  maxAge    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club         Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gradeFilters DynamicGroupGradeLevel[]
  courseSlots        CourseSlot[]
  messageCampaigns   MessageCampaign[]
  memberAssignments  MemberDynamicGroup[]
  invoiceLines       InvoiceLine[]

  @@index([clubId])
}

model DynamicGroupGradeLevel {
  dynamicGroupId String
  gradeLevelId   String

  dynamicGroup DynamicGroup @relation(fields: [dynamicGroupId], references: [id], onDelete: Cascade)
  gradeLevel   GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@id([dynamicGroupId, gradeLevelId])
}

// --- Module Familles (foyer, payeur unique, profils visionneur) ---

enum FamilyMemberLinkRole {
  PAYER
  MEMBER
}

model Family {
  id        String   @id @default(uuid())
  clubId    String
  label     String?
  householdGroupId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club           Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  householdGroup HouseholdGroup? @relation("FamilyInHouseholdGroup", fields: [householdGroupId], references: [id], onDelete: SetNull)
  carrierForHouseholdGroup HouseholdGroup? @relation("HouseholdGroupCarrier")
  familyMembers  FamilyMember[]
  invoices       Invoice[]

  @@index([clubId])
  @@index([householdGroupId])
}

/// Foyer étendu : plusieurs `Family` (résidences) partagent facturation et enfants (spec 2026-03-31).
model HouseholdGroup {
  id        String   @id @default(uuid())
  clubId    String
  label     String?
  /// Foyer porteur transitoire pour factures encore rattachées à `Invoice.familyId` (spec §6.1).
  carrierFamilyId String? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club          Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  families      Family[]  @relation("FamilyInHouseholdGroup")
  carrierFamily Family?   @relation("HouseholdGroupCarrier", fields: [carrierFamilyId], references: [id], onDelete: SetNull)
  invoices      Invoice[]

  @@index([clubId])
}

/// Lien foyer ↔ personne : `MEMBER` → `memberId` requis ; `PAYER` → `memberId` ou `contactId` (exactement un des deux).
model FamilyMember {
  id        String               @id @default(uuid())
  familyId  String
  memberId  String?
  contactId String?
  linkRole  FamilyMemberLinkRole @default(MEMBER)
  createdAt DateTime             @default(now())

  family  Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member  Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contact Contact? @relation("FamilyMemberPayerContact", fields: [contactId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([contactId])
}

// --- Module Planning (créneaux, lieux, conflits professeur) ---

model Venue {
  id          String   @id @default(uuid())
  clubId      String
  name        String
  addressLine String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  courseSlots CourseSlot[]

  @@index([clubId])
}

model CourseSlot {
  id             String   @id @default(uuid())
  clubId         String
  venueId        String
  coachMemberId  String
  title          String
  startsAt       DateTime
  endsAt         DateTime
  dynamicGroupId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  venue        Venue         @relation(fields: [venueId], references: [id], onDelete: Restrict)
  coachMember  Member        @relation("CourseSlotCoach", fields: [coachMemberId], references: [id], onDelete: Restrict)
  dynamicGroup DynamicGroup? @relation(fields: [dynamicGroupId], references: [id], onDelete: SetNull)

  @@index([clubId, coachMemberId])
  @@index([clubId, startsAt])
}

// --- Adhésion : saisons, groupes persistés, formules, lignes de facture ---

model ClubSeason {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  startsOn  DateTime @db.Date
  endsOn    DateTime @db.Date
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club     Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([clubId])
}

model MemberDynamicGroup {
  id             String   @id @default(uuid())
  clubId         String
  memberId       String
  dynamicGroupId String
  createdAt      DateTime @default(now())

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  dynamicGroup DynamicGroup @relation(fields: [dynamicGroupId], references: [id], onDelete: Cascade)

  @@unique([memberId, dynamicGroupId])
  @@index([clubId, memberId])
}

model MembershipProduct {
  id                      String    @id @default(uuid())
  clubId                  String
  label                   String
  annualAmountCents       Int
  monthlyAmountCents      Int
  minAge                  Int?
  maxAge                  Int?
  allowProrata            Boolean   @default(true)
  allowFamily             Boolean   @default(true)
  allowPublicAid          Boolean   @default(true)
  allowExceptional        Boolean   @default(true)
  exceptionalCapPercentBp Int?
  archivedAt              DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  club          Club                         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gradeFilters  MembershipProductGradeLevel[]
  invoiceLines  InvoiceLine[]

  @@index([clubId])
}

model MembershipProductGradeLevel {
  membershipProductId String
  gradeLevelId        String

  membershipProduct MembershipProduct @relation(fields: [membershipProductId], references: [id], onDelete: Cascade)
  gradeLevel        GradeLevel        @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@id([membershipProductId, gradeLevelId])
}

model MembershipOneTimeFee {
  id           String    @id @default(uuid())
  clubId       String
  label        String
  amountCents  Int
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoiceLines InvoiceLine[]

  @@index([clubId])
}

enum InvoiceLineKind {
  MEMBERSHIP_SUBSCRIPTION
  MEMBERSHIP_ONE_TIME
}

enum SubscriptionBillingRhythm {
  ANNUAL
  MONTHLY
}

enum InvoiceLineAdjustmentType {
  PRORATA_SEASON
  FAMILY
  PUBLIC_AID
  EXCEPTIONAL
}

model InvoiceLine {
  id                       String                     @id @default(uuid())
  invoiceId                String
  kind                     InvoiceLineKind            @default(MEMBERSHIP_SUBSCRIPTION)
  memberId                 String
  membershipProductId      String?
  membershipOneTimeFeeId   String?
  subscriptionBillingRhythm SubscriptionBillingRhythm?
  dynamicGroupId           String?
  baseAmountCents          Int
  sortOrder                Int                        @default(0)

  invoice            Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  member             Member                @relation(fields: [memberId], references: [id], onDelete: Restrict)
  membershipProduct  MembershipProduct?    @relation(fields: [membershipProductId], references: [id], onDelete: SetNull)
  membershipOneTimeFee MembershipOneTimeFee? @relation(fields: [membershipOneTimeFeeId], references: [id], onDelete: SetNull)
  dynamicGroup       DynamicGroup?         @relation(fields: [dynamicGroupId], references: [id], onDelete: SetNull)
  adjustments        InvoiceLineAdjustment[]

  @@index([invoiceId])
  @@index([memberId])
}

model InvoiceLineAdjustment {
  id               String                    @id @default(uuid())
  lineId           String
  stepOrder        Int
  type             InvoiceLineAdjustmentType
  amountCents      Int
  percentAppliedBp Int?
  metadataJson     String?
  reason           String?
  createdByUserId  String?

  line InvoiceLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@index([lineId])
}

// --- Phase E : Paiement (factures, encaissements, tarification, Stripe) ---

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

enum ClubPaymentMethod {
  STRIPE_CARD
  MANUAL_CASH
  MANUAL_CHECK
  MANUAL_TRANSFER
}

enum PricingAdjustmentType {
  NONE
  PERCENT_BP
  FIXED_CENTS
}

model ClubPricingRule {
  id              String                @id @default(uuid())
  clubId          String
  method          ClubPaymentMethod
  adjustmentType  PricingAdjustmentType @default(NONE)
  adjustmentValue Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, method])
  @@index([clubId])
}

model Invoice {
  id                    String        @id @default(uuid())
  clubId                String
  familyId              String?
  householdGroupId      String?
  clubSeasonId          String?
  label                 String
  baseAmountCents       Int
  amountCents           Int
  status                InvoiceStatus @default(OPEN)
  lockedPaymentMethod   ClubPaymentMethod?
  dueAt                 DateTime?
  stripePaymentIntentId String?       @unique
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  club       Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  family     Family?     @relation(fields: [familyId], references: [id], onDelete: SetNull)
  householdGroup HouseholdGroup? @relation(fields: [householdGroupId], references: [id], onDelete: SetNull)
  clubSeason ClubSeason? @relation(fields: [clubSeasonId], references: [id], onDelete: SetNull)
  lines      InvoiceLine[]
  payments   Payment[]

  @@index([clubId, status])
  @@index([clubId, householdGroupId, status])
  @@index([clubSeasonId])
}

model Payment {
  id          String            @id @default(uuid())
  clubId      String
  invoiceId   String
  amountCents Int
  method      ClubPaymentMethod
  externalRef String?
  /// Payeur réel (portail / traçabilité). Null = encaissement club catalogué sans fiche membre payeur.
  paidByMemberId String?
  /// Payeur contact (sans fiche `Member`). Au plus un de `paidByMemberId` / `paidByContactId` (appli).
  paidByContactId String?
  createdAt   DateTime          @default(now())

  club    Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  paidByMember Member? @relation("PaymentPaidByMember", fields: [paidByMemberId], references: [id], onDelete: SetNull)
  paidByContact Contact? @relation("PaymentPaidByContact", fields: [paidByContactId], references: [id], onDelete: SetNull)
  accountingEntries AccountingEntry[]

  @@index([clubId, createdAt])
  @@index([invoiceId])
  @@index([paidByMemberId])
  @@index([paidByContactId])
}

model StripeWebhookEvent {
  id          String   @id
  processedAt DateTime @default(now())
}

// --- Phase F : Communication (campagnes, audience = groupes dynamiques) ---

enum CommunicationChannel {
  EMAIL
  TELEGRAM
  PUSH
}

enum MessageCampaignStatus {
  DRAFT
  SENT
}

model MessageCampaign {
  id             String                  @id @default(uuid())
  clubId         String
  title          String
  body           String
  channel        CommunicationChannel
  dynamicGroupId String?
  status         MessageCampaignStatus     @default(DRAFT)
  sentAt         DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  club           Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  dynamicGroup   DynamicGroup? @relation(fields: [dynamicGroupId], references: [id], onDelete: SetNull)
  recipients     MessageCampaignRecipient[]

  @@index([clubId])
}

model MessageCampaignRecipient {
  id         String   @id @default(uuid())
  campaignId String
  memberId   String
  createdAt  DateTime @default(now())

  campaign MessageCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  member   Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([campaignId, memberId])
  @@index([memberId])
}

/// Domaine d’envoi e-mail du club (ESP + statut DNS).
enum ClubSendingDomainPurpose {
  TRANSACTIONAL
  CAMPAIGN
  BOTH
}

enum ClubSendingDomainVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

model ClubSendingDomain {
  id                 String                              @id @default(uuid())
  clubId             String
  fqdn               String
  purpose            ClubSendingDomainPurpose
  verificationStatus ClubSendingDomainVerificationStatus @default(PENDING)
  providerDomainId   String?
  dnsRecordsJson     String?
  lastCheckedAt      DateTime?
  createdAt          DateTime                            @default(now())
  updatedAt          DateTime                            @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, fqdn])
  @@index([clubId])
}

/// Adresses exclues des campagnes (bounce dur, plainte ESP).
model EmailSuppression {
  id              String   @id @default(uuid())
  clubId          String
  emailNormalized String
  reason          String
  createdAt       DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, emailNormalized])
  @@index([clubId])
}

// --- Phase G : Comptabilité (écritures) + stubs Subventions / Sponsoring ---

enum AccountingEntryKind {
  INCOME
  EXPENSE
}

model AccountingEntry {
  id          String              @id @default(uuid())
  clubId      String
  kind        AccountingEntryKind
  label       String
  amountCents Int
  paymentId   String?
  occurredAt  DateTime            @default(now())
  createdAt   DateTime            @default(now())

  club    Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([clubId, occurredAt])
}

enum GrantApplicationStatus {
  DRAFT
  SUBMITTED
  ARCHIVED
}

model GrantApplication {
  id          String                 @id @default(uuid())
  clubId      String
  title       String
  status      GrantApplicationStatus @default(DRAFT)
  amountCents Int?
  notes       String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
}

enum SponsorshipDealStatus {
  ACTIVE
  CLOSED
}

model SponsorshipDeal {
  id          String                @id @default(uuid())
  clubId      String
  sponsorName String
  amountCents Int?
  status      SponsorshipDealStatus @default(ACTIVE)
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
}
