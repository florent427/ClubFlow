# ============================================================
# apps/api/.env STAGING — copier en .env sur le VPS staging
# ============================================================

NODE_ENV=staging
PORT=3100

# DB locale au VPS staging (créée par bootstrap-staging-vps.sh)
DATABASE_URL="postgresql://clubflow_staging:staging_dev_password_change_me@localhost:5432/clubflow_staging?schema=public"

# JWT (à régénérer pour staging — DIFFÉRENT de prod)
JWT_SECRET=staging-CHANGE-ME-32-chars-minimum
JWT_EXPIRES_IN=7d

# CORS — origins staging uniquement
ADMIN_WEB_ORIGIN="https://staging.app.clubflow.topdigital.re,https://staging.clubflow.topdigital.re,https://staging.portail.clubflow.topdigital.re,http://localhost:5173,http://localhost:5174"
CORS_ALLOW_NO_ORIGIN=true

# URL publique de l'API (sert de base pour mediaAssetUrl, OAuth callback, etc.)
# ⚠️ DOIT être set sinon les uploads PDF (documents à signer) renvoient
# `http://localhost:3000/media/<id>` non joignable depuis le browser.
API_PUBLIC_URL=https://staging.api.clubflow.topdigital.re

# Multi-tenant
VITRINE_PUBLIC_BASE_DOMAIN=staging.clubflow.topdigital.re
VITRINE_UPSTREAM=localhost:5275
CADDY_ADMIN_URL=http://localhost:2019

# Reset password URL (priorité admin staging)
ADMIN_WEB_ORIGIN_PRIMARY=https://staging.app.clubflow.topdigital.re
MEMBER_PORTAL_ORIGIN=https://staging.portail.clubflow.topdigital.re

# === Mail SMTP — sandbox Brevo distinct prod ===
# Génère une SMTP key séparée pour staging dans Brevo dashboard.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ClubFlow Staging <noreply@clubflow.topdigital.re>
CLUBFLOW_SENDER_EMAIL=noreply@clubflow.topdigital.re

# === Secrets chiffrés par club ===
# 🔴 Clé maîtresse qui déchiffre TOUS les secrets stockés par club
# (clé OpenRouter de l'IA, futurs secrets PSP). Si perdue, ces secrets sont
# irrécupérables et doivent être re-saisis club par club.
# DIFFÉRENTE de la prod. Générer : openssl rand -base64 32
AI_SECRETS_KEY=staging-CHANGE-ME-32B-BASE64

# === Stripe — clés de TEST uniquement sur staging ===
# ⚠️ JAMAIS de clé live ici. Dashboard Stripe en mode Test :
#   Developers → API keys           → sk_test_...
#   Developers → Webhooks → endpoint → whsec_...
# L'endpoint webhook à déclarer côté Stripe :
#   https://staging.api.clubflow.topdigital.re/webhooks/stripe
# Événement minimal requis aujourd'hui : payment_intent.succeeded
# Sans ces variables, le Checkout d'adhésion et le passage des factures en
# PAID sont inopérants sur staging (donc non testables avant la prod).
# Cf. docs/memory/decisions/0008-stripe-connect-express.md
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# === hCaptcha sandbox keys ===
# Cf. https://docs.hcaptcha.com/#integration-testing-test-keys
# 10000000-ffff-ffff-ffff-000000000001 = always-pass site key (test only)
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# Captcha optionnel en staging (utile pour tests automatisés)
# CAPTCHA_DISABLED=true
