# Base — copier vers .env.local
# URL GraphQL de l'API NestJS (server-side, jamais exposée au client).
VITRINE_API_URL=http://localhost:3000/graphql

# Slug du club par défaut servi par la vitrine.
# En production multi-club, la résolution se fait par hostname via middleware.ts.
VITRINE_DEFAULT_CLUB_SLUG=demo-club

# Secret partagé entre l'API et la vitrine pour le webhook ISR /api/revalidate.
# L'API envoie ce secret dans le header X-Revalidate-Secret.
VITRINE_REVALIDATE_SECRET=change-me-revalidate

# Cookie name used to detect admin edit mode.
VITRINE_EDIT_COOKIE_NAME=clubflow_vitrine_edit

# URL publique admin (pour les redirections depuis le site → back-office)
VITRINE_ADMIN_URL=http://localhost:5173

# Clé JWT (même secret que JWT_SECRET de l'API) pour vérifier le cookie edit mode.
VITRINE_JWT_SECRET=change-me
