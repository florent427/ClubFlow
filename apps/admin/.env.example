# URL HTTP du endpoint GraphQL NestJS
VITE_GRAPHQL_HTTP=http://localhost:3000/graphql
# URL WS pour la messagerie temps-réel
VITE_GRAPHQL_WS=ws://localhost:3000/chat
# Base URL des médias servis par l'API (uploads OCR, photos)
VITE_MEDIA_BASE=http://localhost:3000/media

# Optionnel : pré-remplit le champ « Identifiant club » sur la page de connexion (UUID affiché par npm run db:seed)
# VITE_DEV_CLUB_ID=

# Domaine de la landing marketing (utilisé pour le bouton "Pas encore de club ? S'inscrire")
VITE_LANDING_URL=http://localhost:5176
