# Dépendances
node_modules/

# Fichiers locaux / OS
.DS_Store
Thumbs.db

# IDE / outils locaux (Cursor, agents)
.cursor/
.agent/
design stich/

# Env (les secrets restent hors dépôt ; utiliser .env.example)
.env
.env.local
*.log

# Claude Code worktree metadata (contient login JWT, logs, etc.)
.claude/*
# ... mais on versionne les skills custom partagés (équipe + multi-machine)
!.claude/skills/

# Comptes de test staging (jamais commit)
staging-test-accounts.local.md

# Scripts SQL opérationnels : contiennent des noms réels, des identifiants
# utilisateur et des manipulations de base. Le dépôt est PUBLIC.
bin/*.sql

# Clé de compte de service Google Play (publication mobile).
# JAMAIS dans le dépôt : elle autorise à publier sous l'identité de l'éditeur.
# Référencée par chemin absolu depuis eas.json (serviceAccountKeyPath).
google-play-service-account*.json
**/google-play-service-account*.json
play-store-key*.json
